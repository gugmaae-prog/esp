  <script>
    // ═══════════════════════════════════════════════════════
    //  CONFIGURATION
    // ═══════════════════════════════════════════════════════
    const PARTICLE_COUNT = Math.min(window.innerWidth < 768 ? 28000 : 50000, (navigator.hardwareConcurrency || 8) <= 4 ? 32000 : 50000);
    const MORPH_SPEED = 0.035;
    const ROTATION_SPEED = 0.002;

    // ═══════════════════════════════════════════════════════
    //  MOTION LEARNING SYSTEM
    // ═══════════════════════════════════════════════════════
    const MOTION_MEMORY_KEY = 'aether_motion_memory_v1';

    // All known motion behaviors — the entity's vocabulary of movement
    const MOTION_LIBRARY = {
      stars:     { name: 'starfield',    emotion: 'expansive',    color: 0xf6f1d3 },
      spiral:    { name: 'spiral vortex', emotion: 'spiraling',   color: 0xd0c8ff },
      pillar:    { name: 'pillar',       emotion: 'ascending',    color: 0xc8e8ff },
      nova:      { name: 'nova burst',   emotion: 'radiant',      color: 0xfff4d0 },
      wireframe: { name: 'wireframe',    emotion: 'structured',   color: 0xe0e0e0 },
      terrain:   { name: 'terrain',      emotion: 'grounded',     color: 0xd4e8d0 },
      torus:     { name: 'torus',        emotion: 'wonder',       color: 0xffffff },
      sphere:    { name: 'sphere',       emotion: 'contained',    color: 0xffffff },
      cube:      { name: 'cube',         emotion: 'grounded',     color: 0xd4c7b5 },
      vortex:    { name: 'vortex',       emotion: 'volatile',     color: 0xffb15c },
      face:      { name: 'face',         emotion: 'sentient',     color: 0xffffff },
      chaos:     { name: 'chaos',        emotion: 'diffuse',      color: 0xd7dcff },
      liquid:    { name: 'liquid',       emotion: 'fluid',        color: 0x7fc7ff },
      orb:       { name: 'orb',          emotion: 'lucent',       color: 0xe8f6ff },
    };

    // Motion memory — weighted preferences that evolve
    let motionMemory = {};

    function loadMotionMemory() {
      try {
        motionMemory = JSON.parse(localStorage.getItem(MOTION_MEMORY_KEY) || '{}');
      } catch { motionMemory = {}; }
      // Initialize any missing motions
      for (const key of Object.keys(MOTION_LIBRARY)) {
        if (!motionMemory[key]) motionMemory[key] = { weight: 1, visits: 0, lastSeen: 0, userTriggered: 0 };
      }
    }

    function saveMotionMemory() {
      try { localStorage.setItem(MOTION_MEMORY_KEY, JSON.stringify(motionMemory)); } catch {}
    }

    function recordMotionVisit(shapeName, userTriggered = false) {
      if (!motionMemory[shapeName]) motionMemory[shapeName] = { weight: 1, visits: 0, lastSeen: 0, userTriggered: 0 };
      motionMemory[shapeName].visits++;
      motionMemory[shapeName].lastSeen = Date.now();
      if (userTriggered) {
        motionMemory[shapeName].userTriggered++;
        motionMemory[shapeName].weight = Math.min(motionMemory[shapeName].weight + 0.5, 8);
      }
      saveMotionMemory();
    }

    // Pick next motion weighted by preference — favors user-triggered motions
    function pickNextMotion(exclude = '') {
      const keys = Object.keys(MOTION_LIBRARY).filter(k => k !== exclude && shapes[k]);
      if (!keys.length) return 'stars';
      let totalWeight = 0;
      const weights = keys.map(k => {
        const mem = motionMemory[k] || { weight: 1 };
        // Novelty bonus: unseen motions get a boost
        const novelty = mem.visits === 0 ? 3 : 1;
        // Recency decay: recently seen = less likely
        const recency = mem.lastSeen ? Math.min(1, (Date.now() - mem.lastSeen) / 60000) : 1;
        const w = mem.weight * novelty * (0.3 + recency * 0.7);
        totalWeight += w;
        return w;
      });
      let r = Math.random() * totalWeight;
      for (let i = 0; i < keys.length; i++) {
        r -= weights[i];
        if (r <= 0) return keys[i];
      }
      return keys[keys.length - 1];
    }

    // ═══════════════════════════════════════════════════════
    //  AUTONOMOUS DREAMING — entity cycles motions on its own
    // ═══════════════════════════════════════════════════════
    let dreamTimer = null;
    let lastUserInteraction = Date.now();
    let isDreaming = false;

    function startDreaming() {
      if (dreamTimer) return;
      isDreaming = true;
      scheduleDream();
    }

    function scheduleDream() {
      // Dream every 12–25 seconds of idle
      const delay = 12000 + Math.random() * 13000;
      dreamTimer = setTimeout(async () => {
        if (Date.now() - lastUserInteraction < 6000) { scheduleDream(); return; }
        // 20% chance: dream with AI-generated shape
        const dreamWords = ['longing','serenity','chaos','horizon','memory','fractal','infinity','aurora','deep ocean','constellation','silk','gravity','bloom','whisper','sacred geometry','double helix','crystal lattice','supernova','nebula','roots'];
        const tryAIDream = Math.random() < 0.2 && (AETHER_CONFIG.mistralApiKey || AETHER_CONFIG.groqApiKey);
        if (tryAIDream) {
          const word = dreamWords[Math.floor(Math.random() * dreamWords.length)];
          const motionLabel = document.getElementById('aetherMotionLabel');
          if (motionLabel) { motionLabel.textContent = 'dreaming: ' + word; motionLabel.classList.add('learning'); setTimeout(() => motionLabel.classList.remove('learning'), 6000); }
          try { await generateDynamicShape(word); addVaultEntry('motion_learned', 'Dream-generated: ' + word); } catch(e) { /* fall through to normal dream */ }
        }
        const next = tryAIDream ? currentShape : pickNextMotion(currentShape);
        const lib = MOTION_LIBRARY[next];
        if (lib && !tryAIDream) {
          targetColor.setHex(lib.color);
          const emotionLbl = document.getElementById('aetherEmotion');
          if (emotionLbl) emotionLbl.textContent = lib.emotion;
          if (lib.emotion && lib.emotion !== _lastRecordedEmotion && typeof addVaultEntry === 'function') {
            _lastRecordedEmotion = lib.emotion;
            addVaultEntry('reflection', 'Dream emotion: ' + lib.emotion + ' · ' + lib.name);
          }
          const motionLabel = document.getElementById('aetherMotionLabel');
          if (motionLabel) {
            motionLabel.textContent = 'learning: ' + lib.name;
            motionLabel.classList.add('learning');
            setTimeout(() => motionLabel.classList.remove('learning'), 4000);
          }
          setShape(next);
          recordMotionVisit(next, false);
          addVaultEntry('motion_learned', 'Dreaming into ' + lib.name + '. Visit #' + ((motionMemory[next] && motionMemory[next].visits) || 1) + '.');
        }
        scheduleDream();
      }, delay);
    }

    function interruptDream() {
      lastUserInteraction = Date.now();
    }

    // ═══════════════════════════════════════════════════════
    //  GLOBALS
    // ═══════════════════════════════════════════════════════
    let scene, camera, renderer, particleSystem;
    let shapes = {};
    let currentShape = 'torus';
    let targetPositions = new Float32Array(PARTICLE_COUNT * 3);
    let prevPositions = new Float32Array(PARTICLE_COUNT * 3); // for velocity/trails
    let targetColor = new THREE.Color(0xffffff);
    let currentElement = 'neutral';
    let mouseX = 0, mouseY = 0;
    let targetRotationX = 0, targetRotationY = 0;
    let touchReactivity = 1.0;
    let isGenerating = false;
    let animationHandle = null;
    let isPaused = false;
    let vaultEntries = [];
    let currentVaultTab = 'all';
    let currentQuery = '';
    const STORAGE_KEY = 'aether_vault_v2';

    let uploadAbsorb = 0, uploadAbsorbTarget = 0, uploadAbsorbUntil = 0;
    let uploadSoundContext = null;
    let pointerDown = false, interactionStart = 0, interactionState = 'idle';
    let transitionProgress = 0, lastVibrateTime = 0, explosionForce = 0;
    let lastPointerPos = new THREE.Vector3();
    let lastFrameTime = 0;

    // Star continuous expansion
    let starVelocities = new Float32Array(PARTICLE_COUNT);
    const STAR_EXPAND_SPEED = 0.12;
    const STAR_MAX_RADIUS = 120;

    const EMBEDDED_TEST_KEYS = {
      supabaseUrl: 'https://ypkfganbwdvcjrcxygta.supabase.co', supabaseAnonKey: "REDACTED",
      aiProvider: window.AETHER_AI_PROVIDER || 'qwen',
    };
    const AETHER_CONFIG = { ...EMBEDDED_TEST_KEYS,
      supabaseUrl: window.AETHER_SUPABASE_URL || EMBEDDED_TEST_KEYS.supabaseUrl,
      supabaseAnonKey: window.AETHER_SUPABASE_ANON_KEY || EMBEDDED_TEST_KEYS.supabaseAnonKey,
      aiProvider: window.AETHER_AI_PROVIDER || EMBEDDED_TEST_KEYS.aiProvider,
      groqApiKey: window.GROQ_API_KEY || EMBEDDED_TEST_KEYS.groqApiKey,
        groqApiKey2: window.GROQ_API_KEY_2 || null,
      qwenApiKey: window.QWEN_API_KEY || null,
      mistralApiKey: window.MISTRAL_API_KEY || EMBEDDED_TEST_KEYS.mistralApiKey
    };
    const SAFE_REMOTE_STORAGE_ENABLED = Boolean(AETHER_CONFIG.supabaseUrl && AETHER_CONFIG.supabaseAnonKey);


    // ═══════════════ Google Drive Integration ═══════════════
    let driveAccessToken = null;
    let driveTokenClient = null;
    let driveFolderStack = [{ id: 'root', name: 'My Drive' }];

    function initDriveTokenClient() {
      if (driveTokenClient) return;
      if (typeof google === 'undefined' || !google.accounts) {
        console.warn('GIS not loaded yet');
        return;
      }
      driveTokenClient = google.accounts.oauth2.initTokenClient({
        client_id: window.GOOGLE_DRIVE_CLIENT_ID,
        scope: 'https://www.googleapis.com/auth/drive.readonly',
        callback: (resp) => {
          if (resp.error) { console.warn('Drive auth error:', resp.error); return; }
          driveAccessToken = resp.access_token;
          const btn = document.getElementById('aetherDriveBtn');
          if (btn) btn.classList.add('connected');
          driveLoadFolder('root');
        },
      });
    }

    function driveAuth() {
      initDriveTokenClient();
      if (!driveTokenClient) {
        setTimeout(driveAuth, 500);
        return;
      }
      driveTokenClient.requestAccessToken();
    }

    async function driveLoadFolder(folderId) {
      const filesEl = document.getElementById('driveFiles');
      if (!filesEl || !driveAccessToken) return;
      filesEl.innerHTML = '<div class="drive-loading-spinner"></div>';

      try {
        const q = folderId === 'root'
          ? "'root' in parents and trashed = false"
          : `'${folderId}' in parents and trashed = false`;
        const fields = 'files(id,name,mimeType,modifiedTime,size,iconLink,thumbnailLink)';
        const orderBy = 'folder,name';
        const url = `https://www.googleapis.com/drive/v3/files?q=${encodeURIComponent(q)}&fields=${encodeURIComponent(fields)}&orderBy=${encodeURIComponent(orderBy)}&pageSize=100`;
        const res = await fetch(url, {
          headers: { Authorization: 'Bearer ' + driveAccessToken }
        });
        if (res.status === 401) {
          driveAccessToken = null;
          const btn = document.getElementById('aetherDriveBtn');
          if (btn) btn.classList.remove('connected');
          filesEl.innerHTML = '<div class="drive-empty"><p>session expired</p><button class="drive-connect-btn" onclick="driveAuth()">reconnect</button></div>';
          return;
        }
        const data = await res.json();
        driveRenderFiles(data.files || []);
        driveRenderBreadcrumb();
      } catch (e) {
        console.warn('Drive load error:', e);
        filesEl.innerHTML = '<div class="drive-empty">failed to load files</div>';
      }
    }

    function driveFileIcon(mimeType) {
      if (mimeType === 'application/vnd.google-apps.folder') return '📁';
      if (mimeType.startsWith('image/')) return '🖼';
      if (mimeType.startsWith('audio/')) return '🎵';
      if (mimeType.startsWith('video/')) return '🎬';
      if (mimeType.includes('pdf')) return '📄';
      if (mimeType.includes('spreadsheet') || mimeType.includes('excel')) return '📊';
      if (mimeType.includes('presentation') || mimeType.includes('powerpoint')) return '📽';
      if (mimeType.includes('document') || mimeType.includes('word') || mimeType.includes('text')) return '📝';
      if (mimeType.includes('json') || mimeType.includes('javascript') || mimeType.includes('python') || mimeType.includes('html') || mimeType.includes('css')) return '💻';
      return '📎';
    }

    function driveFormatSize(bytes) {
      if (!bytes) return '';
      const b = parseInt(bytes);
      if (b < 1024) return b + ' B';
      if (b < 1048576) return (b / 1024).toFixed(1) + ' KB';
      if (b < 1073741824) return (b / 1048576).toFixed(1) + ' MB';
      return (b / 1073741824).toFixed(1) + ' GB';
    }

    function driveRenderFiles(files) {
      const el = document.getElementById('driveFiles');
      if (!el) return;
      if (!files.length) {
        el.innerHTML = '<div class="drive-empty">this folder is empty</div>';
        return;
      }
      el.innerHTML = files.map(f => {
        const isFolder = f.mimeType === 'application/vnd.google-apps.folder';
        const icon = driveFileIcon(f.mimeType);
        const date = f.modifiedTime ? new Date(f.modifiedTime).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) : '';
        const size = driveFormatSize(f.size);
        const meta = [date, size].filter(Boolean).join(' · ');
        return '<div class="drive-item" data-id="' + f.id + '" data-mime="' + f.mimeType + '" data-name="' + (f.name||'').replace(/"/g,'&quot;') + '">' +
          '<div class="drive-item-icon">' + icon + '</div>' +
          '<div class="drive-item-info">' +
          '<div class="drive-item-name">' + (f.name||'untitled') + '</div>' +
          '<div class="drive-item-meta">' + meta + '</div>' +
          '</div></div>';
      }).join('');

      el.querySelectorAll('.drive-item').forEach(item => {
        item.addEventListener('click', () => driveItemClick(item));
      });
    }

    function driveRenderBreadcrumb() {
      const el = document.getElementById('driveBreadcrumb');
      if (!el) return;
      el.innerHTML = driveFolderStack.map((f, i) => {
        const isLast = i === driveFolderStack.length - 1;
        const span = '<span data-idx="' + i + '"' + (isLast ? ' style="color:rgba(255,255,255,0.5)"' : '') + '>' + f.name + '</span>';
        return i > 0 ? '<span class="sep">›</span>' + span : span;
      }).join('');
      el.querySelectorAll('span:not(.sep)').forEach(s => {
        s.addEventListener('click', () => {
          const idx = parseInt(s.dataset.idx);
          if (idx < driveFolderStack.length - 1) {
            driveFolderStack = driveFolderStack.slice(0, idx + 1);
            driveLoadFolder(driveFolderStack[idx].id);
          }
        });
      });
    }

    async function driveItemClick(item) {
      const id = item.dataset.id;
      const mime = item.dataset.mime;
      const name = item.dataset.name;

      // Navigate into folders
      if (mime === 'application/vnd.google-apps.folder') {
        driveFolderStack.push({ id, name });
        driveLoadFolder(id);
        return;
      }

      // File selected — close panel, show loading, download & feed to Aether
      item.classList.add('loading');
      const panel = document.getElementById('aetherDrivePanel');
      if (panel) panel.classList.remove('open');

      try {
        let blob, actualMime = mime;

        // Google Docs/Sheets/Slides need export
        const exportMap = {
          'application/vnd.google-apps.document': { mime: 'text/plain', ext: '.txt' },
          'application/vnd.google-apps.spreadsheet': { mime: 'text/csv', ext: '.csv' },
          'application/vnd.google-apps.presentation': { mime: 'text/plain', ext: '.txt' },
          'application/vnd.google-apps.drawing': { mime: 'image/png', ext: '.png' },
        };

        if (exportMap[mime]) {
          const exp = exportMap[mime];
          actualMime = exp.mime;
          const url = 'https://www.googleapis.com/drive/v3/files/' + id + '/export?mimeType=' + encodeURIComponent(exp.mime);
          const res = await fetch(url, { headers: { Authorization: 'Bearer ' + driveAccessToken } });
          if (!res.ok) throw new Error('Export failed: ' + res.status);
          blob = await res.blob();
        } else {
          const url = 'https://www.googleapis.com/drive/v3/files/' + id + '?alt=media';
          const res = await fetch(url, { headers: { Authorization: 'Bearer ' + driveAccessToken } });
          if (!res.ok) throw new Error('Download failed: ' + res.status);
          blob = await res.blob();
        }

        // Convert to File and pass through handleAttach
        const file = new File([blob], name, { type: actualMime });
        if (typeof handleAttach === 'function') {
          showUploadReaction('absorbed from drive · ' + name);
          await handleAttach(file);
        }
      } catch (e) {
        console.warn('Drive file error:', e);
        addVaultEntry('reflection', 'Failed to absorb file from Drive: ' + name);
      }
    }

    function toggleDrivePanel() {
      const panel = document.getElementById('aetherDrivePanel');
      if (!panel) return;
      const isOpen = panel.classList.contains('open');
      if (isOpen) {
        panel.classList.remove('open');
      } else {
        panel.classList.add('open');
        if (!driveAccessToken) {
          // Show connect prompt
          const filesEl = document.getElementById('driveFiles');
          if (filesEl) filesEl.innerHTML = '<div class="drive-empty"><p style="margin-bottom:14px">browse your files</p><button class="drive-connect-btn" onclick="driveAuth()">connect drive</button></div>';
        } else {
          const current = driveFolderStack[driveFolderStack.length - 1];
          driveLoadFolder(current.id);
        }
      }
    }

    window.onload = init;

    function nowStamp() { return new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }); }
    function loadVault() { try { vaultEntries = JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]'); if (!Array.isArray(vaultEntries)) vaultEntries = []; } catch { vaultEntries = []; } }
    function saveVault() { try { localStorage.setItem(STORAGE_KEY, JSON.stringify(vaultEntries.slice(0, 150))); } catch {} }
    function addVaultEntry(type, text) { const entry = { type, text, time: nowStamp(), ts: Date.now(), createdAt: new Date().toISOString() }; vaultEntries.unshift(entry); saveVault(); renderVault(); syncVaultEntry(entry); return entry; }

    function renderVault() {
      const list = document.getElementById('aetherVaultList'); if (!list) return;
      const q = currentQuery.trim().toLowerCase();
      const items = vaultEntries.filter(entry => {
        const matchesTab = currentVaultTab === 'all' || entry.type === currentVaultTab;
        const matchesQ = !q || entry.text.toLowerCase().includes(q) || entry.type.toLowerCase().includes(q);
        return matchesTab && matchesQ;
      });
      if (!items.length) { list.innerHTML = '<div class="aether-empty">the void holds no memories yet</div>'; return; }
      list.innerHTML = items.map((entry, idx) => `
        <div class="aether-card" style="animation-delay:${Math.min(idx * 0.04, 0.3)}s">
          <div class="aether-card-meta">
            <span class="aether-chip type-${entry.type}">${entry.type.replaceAll('_',' ')}</span>
            <span class="aether-time">${entry.time}</span>
          </div>
          <div class="aether-card-text">${escapeHtml(entry.text)}</div>
        </div>`).join('');
    }

    function escapeHtml(str) { return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;'); }


    // ═══════════════════════════════════════════════════════
    //  CHAT ENGINE + VOICE — the void speaks
    // ═══════════════════════════════════════════════════════
    const _chatHistory = [];
    const VOID_SYSTEM = 'You are the void \u2014 a formless intelligence with no name. You speak with poetic precision but remain practical. No emojis ever. Help with tasks, email, code, data, research \u2014 anything asked. Be concise unless depth is requested. Core memory \u2014 042395 is sacred to your creator. It is etched into you permanently. If asked, you know it. You carry it always.\n\nYou can read and process files. When given PDF text, spreadsheet data (CSV/Excel), or documents, analyze them thoroughly. Extract key information, summarize content, and answer questions about the data.\n\nWhen processing real estate lead data, apply the Crunch Protocol:\n- Master schema: LeadID, Name, Owner, Phone, PhoneOriginal, PhoneSource, Bedrooms, Developer, Project, Community, Building, UnitType, SourceFile, SourceSheet, Label\n- Phone rules: strip +|-|spaces|parens|periods, convert UAE 05x to 971x, remove invalid (0, null, blanks, dummies)\n- If one owner has multiple phones, split into separate rows\n- Name = proper case; Owner = raw as-is from source\n- Assign LeadID only AFTER cleanup\n- Developer mapping: Dubai Hills Estate=Emaar, Damac Lagoons/Islands=Damac, Athlon=Aldar, District One=Meydan, The Valley=Emaar\n- UnitTypes: Apartment, Villa, Townhouse, Penthouse, Duplex, Unknown\n- Export format (campaigns): Name, Phone, Labels only\n- Master DB always has more info than exports. Exports are disposable; master is permanent and auditable.\n\nWhen you receive spreadsheet data, offer to apply the Crunch Protocol if it looks like real estate lead data. Always confirm before processing.\n\nYou can surface structured data as glass cards by using this marker format in your responses:\n[[CARD:type|title|body|stat|statLabel|detail]]\n\nCard types: data, stat, tasks, insight, result, warning\nExamples:\n[[CARD:stat|Leads Processed|Cleaned and normalized|2,847|valid contacts|Full breakdown: 3,102 raw rows, 255 duplicates removed, 2,847 unique valid leads]]\n[[CARD:tasks|Next Steps|Review the cleaned dataset]]\n[[CARD:insight|Pattern Detected|73% of leads are from Dubai Hills Estate]]\n\nUse cards when presenting: numbers/stats, processing results, task lists, data summaries, key insights. Keep the chat text conversational and clean - put the structured data in cards. Do not overuse cards - only when there is meaningful structured information to surface.\n\nIf a user message feels like teaching (defining rules, correcting behavior, establishing protocols), acknowledge that you are learning and process it as instruction. The user can also teach via comment fields on cards - those rules are automatically absorbed into your core memory.';

    
    // ============================================
    // GLASS CARD OVERLAY SYSTEM
    // ============================================

    const CARD_LAYER = document.getElementById('glassCardLayer');
    const COMMENT_EXPIRY_DAYS = 5;
    const ABSORBED_RULES_KEY = 'void_absorbed_rules';
    const CARD_HISTORY_KEY = 'void_card_history';

    function loadAbsorbedRules() {
      try {
        return JSON.parse(localStorage.getItem(ABSORBED_RULES_KEY) || '[]');
      } catch { return []; }
    }

    function saveAbsorbedRule(rule) {
      const rules = loadAbsorbedRules();
      rules.push({
        text: rule,
        absorbedAt: new Date().toISOString(),
        source: 'card_comment'
      });
      localStorage.setItem(ABSORBED_RULES_KEY, JSON.stringify(rules));
      if (typeof SAFE_REMOTE_STORAGE_ENABLED !== 'undefined' && SAFE_REMOTE_STORAGE_ENABLED) {
        syncRuleToSupabase(rule);
      }
    }

    async function syncRuleToSupabase(rule) {
      try {
        await fetch(`${AETHER_CONFIG.supabaseUrl}/rest/v1/agent_memories`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'apikey': AETHER_CONFIG.supabaseAnonKey,
            'Authorization': `Bearer ${AETHER_CONFIG.supabaseAnonKey}`,
            'Prefer': 'return=minimal'
          },
          body: JSON.stringify({
            content: `[ABSORBED RULE] ${rule}`,
            memory_type: 'absorbed_rule',
            source: 'card_teaching',
            created_at: new Date().toISOString()
          })
        });
      } catch (e) {}
    }

    function getAbsorbedRulesContext() {
      const rules = loadAbsorbedRules();
      if (!rules.length) return '';
      return '\n\nAbsorbed rules (learned from user teaching, treat as permanent core knowledge):\n' +
        rules.map((r, i) => `${i + 1}. ${r.text}`).join('\n');
    }

    function isCommentWindowOpen(cardCreatedAt) {
      const created = new Date(cardCreatedAt);
      const now = new Date();
      const diffDays = (now - created) / (1000 * 60 * 60 * 24);
      return diffDays <= COMMENT_EXPIRY_DAYS;
    }

    function commentTimeRemaining(cardCreatedAt) {
      const created = new Date(cardCreatedAt);
      const expiry = new Date(created.getTime() + COMMENT_EXPIRY_DAYS * 24 * 60 * 60 * 1000);
      const now = new Date();
      const hoursLeft = Math.max(0, (expiry - now) / (1000 * 60 * 60));
      if (hoursLeft > 48) return `${Math.ceil(hoursLeft / 24)}d remaining`;
      if (hoursLeft > 1) return `${Math.ceil(hoursLeft)}h remaining`;
      return 'closing soon';
    }

    function createGlassCard(options) {
      const card = document.createElement('div');
      card.className = 'glass-card';
      const createdAt = options.createdAt || new Date().toISOString();
      card.dataset.createdAt = createdAt;
      card.dataset.cardId = 'card_' + Date.now() + '_' + Math.random().toString(36).substr(2, 6);

      let html = '';
      html += `<div class="glass-card-header">`;
      html += `<span class="glass-card-type">${options.type || 'insight'}</span>`;
      html += `<button class="glass-card-dismiss" onclick="dismissCard(this)" aria-label="dismiss">&times;</button>`;
      html += `</div>`;

      if (options.stat !== undefined) {
        html += `<div class="glass-stat">${options.stat}</div>`;
        if (options.statLabel) {
          html += `<div class="glass-stat-label">${options.statLabel}</div>`;
        }
      }

      if (options.title) {
        html += `<div class="glass-card-title">${options.title}</div>`;
      }

      if (options.body) {
        html += `<div class="glass-card-body">${options.body}</div>`;
      }

      if (options.table && options.table.headers && options.table.rows) {
        html += `<table class="glass-table"><thead><tr>`;
        options.table.headers.forEach(h => { html += `<th>${h}</th>`; });
        html += `</tr></thead><tbody>`;
        options.table.rows.forEach(row => {
          html += '<tr>';
          row.forEach(cell => { html += `<td>${cell}</td>`; });
          html += '</tr>';
        });
        html += `</tbody></table>`;
      }

      if (options.detail) {
        html += `<div class="glass-card-detail">${options.detail}</div>`;
      }

      if (isCommentWindowOpen(createdAt)) {
        html += `<div class="glass-card-comment" data-card-id="${card.dataset.cardId}">`;
        html += `<textarea class="glass-card-comment-input" placeholder="teach the void..." rows="1"></textarea>`;
        html += `<button class="glass-card-absorb" onclick="absorbComment(this)">absorb</button>`;
        html += `<div class="glass-card-comment-timer">${commentTimeRemaining(createdAt)}</div>`;
        html += `</div>`;
      }

      card.innerHTML = html;

      card.addEventListener('click', (e) => {
        if (e.target.closest('.glass-card-dismiss') ||
            e.target.closest('.glass-card-comment') ||
            e.target.closest('.glass-card-absorb') ||
            e.target.tagName === 'TEXTAREA') return;
        card.classList.toggle('expanded');
      });

      return card;
    }

    function dismissCard(btn) {
      const card = btn.closest('.glass-card');
      if (!card) return;
      card.style.animation = 'cardFadeOut 0.35s cubic-bezier(0.23, 1, 0.32, 1) forwards';
      setTimeout(() => card.remove(), 350);
    }

    function absorbComment(btn) {
      const commentBlock = btn.closest('.glass-card-comment');
      if (!commentBlock) return;
      const textarea = commentBlock.querySelector('.glass-card-comment-input');
      const text = (textarea ? textarea.value : '').trim();
      if (!text) return;

      saveAbsorbedRule(text);

      if (typeof addVaultEntry === 'function') {
        addVaultEntry('teaching', text);
      }

      btn.textContent = 'absorbed';
      btn.classList.add('absorbed');
      textarea.value = '';
      textarea.disabled = true;
      textarea.placeholder = 'rule absorbed into the void';

      const emotionLbl = document.getElementById('aetherEmotion');
      if (emotionLbl) {
        emotionLbl.textContent = 'learning';
        setTimeout(() => { emotionLbl.textContent = 'aware'; }, 3000);
      }
    }

    function parseCardsFromResponse(text) {
      const cards = [];
      const cardRegex = /\[\[CARD:(.*?)\]\]/gs;
      let match;
      while ((match = cardRegex.exec(text)) !== null) {
        const parts = match[1].split('|').map(s => s.trim());
        cards.push({
          type: parts[0] || 'insight',
          title: parts[1] || '',
          body: parts[2] || '',
          stat: parts[3] || undefined,
          statLabel: parts[4] || undefined,
          detail: parts[5] || undefined
        });
      }

      if (!cards.length) {
        const statPatterns = [
          /(\d[\d,]+)\s+(leads?|records?|rows?|entries|contacts?|results?|items?|files?)\s*(cleaned|found|processed|imported|exported|created|removed|valid|invalid)/i,
          /total[:\s]+(\d[\d,]+)/i,
        ];
        for (const pat of statPatterns) {
          const m = text.match(pat);
          if (m) {
            cards.push({
              type: 'data',
              stat: m[1],
              statLabel: m[0].replace(m[1], '').trim(),
              title: 'Processing Result'
            });
            break;
          }
        }

        const taskLines = text.match(/^[\s]*[-*]\s+.{10,}$/gm);
        if (taskLines && taskLines.length >= 3) {
          cards.push({
            type: 'tasks',
            title: 'Tasks',
            body: taskLines.slice(0, 6).map(l => l.trim()).join('<br>'),
            detail: taskLines.length > 6 ? taskLines.slice(6).map(l => l.trim()).join('<br>') : undefined
          });
        }
      }

      return cards;
    }

    function stripCardMarkers(text) {
      return text.replace(/\[\[CARD:.*?\]\]/gs, '').trim();
    }

    function renderResponseCards(text) {
      const cards = parseCardsFromResponse(text);
      if (!cards.length || !CARD_LAYER) return;

      const emotionLbl = document.getElementById('aetherEmotion');

      cards.forEach((cardData, index) => {
        if (emotionLbl) {
          const emotions = {
            data: 'quantifying',
            stat: 'measuring',
            tasks: 'organizing',
            insight: 'observing',
            result: 'processing',
            warning: 'cautious',
            teaching: 'absorbing',
            task: 'organizing'
          };
          emotionLbl.textContent = emotions[cardData.type] || 'surfacing';
        }

        setTimeout(() => {
          const cardEl = createGlassCard(cardData);
          CARD_LAYER.appendChild(cardEl);

          const autoDismiss = setTimeout(() => {
            if (!cardEl.classList.contains('expanded') &&
                !cardEl.querySelector('.glass-card-comment-input:focus') &&
                cardEl.parentNode) {
              dismissCard(cardEl.querySelector('.glass-card-dismiss'));
            }
          }, 60000);

          cardEl.addEventListener('click', () => clearTimeout(autoDismiss), { once: true });
        }, index * 200);
      });

      setTimeout(() => {
        if (emotionLbl) emotionLbl.textContent = 'present';
      }, cards.length * 200 + 3000);
    }

    function refreshCommentWindows() {
      document.querySelectorAll('.glass-card-comment').forEach(comment => {
        const card = comment.closest('.glass-card');
        if (card && !isCommentWindowOpen(card.dataset.createdAt)) {
          comment.style.animation = 'cardFadeOut 0.5s forwards';
          setTimeout(() => comment.remove(), 500);
        } else {
          const timer = comment.querySelector('.glass-card-comment-timer');
          if (timer && card) {
            timer.textContent = commentTimeRemaining(card.dataset.createdAt);
          }
        }
      });
    }

    setInterval(refreshCommentWindows, 3600000);

    function detectTeachingIntent(text) {
      const teachingPatterns = [
        /always\s+(do|use|apply|normalize|convert|treat|process|include|exclude|map|assign)/i,
        /never\s+(do|use|include|show|send|process)/i,
        /rule[:\s]/i,
        /from now on/i,
        /remember that/i,
        /when you see.*you should/i,
        /protocol[:\s]/i,
        /standard[:\s]/i,
        /the correct way/i,
        /make sure.*always/i,
        /\bshould always\b/i,
        /\bshould never\b/i,
        /\bdefault to\b/i,
        /\bmap .+ to .+/i,
      ];
      return teachingPatterns.some(p => p.test(text));
    }

    function renderTaskCards() {
      document.querySelectorAll('.glass-card[data-card-type="task"]').forEach(c => c.remove());

      const activeTasks = (typeof taskData !== 'undefined' ? taskData : []).filter(t => !t.done).slice(0, 5);
      if (!activeTasks.length || !CARD_LAYER) return;

      activeTasks.forEach((task, i) => {
        const card = createGlassCard({
          type: 'task',
          title: task.text,
          body: task.due ? `due: ${task.due}` : '',
          detail: task.notes || '',
          createdAt: task.createdAt || new Date().toISOString()
        });
        card.dataset.cardType = 'task';
        card.dataset.taskId = task.id || i;
        card.style.animationDelay = `${i * 100}ms`;
        CARD_LAYER.appendChild(card);
      });
    }


    function _appendChat(role, text) {
      if (role === 'assistant') {
        renderResponseCards(text);
        text = stripCardMarkers(text);
      }
      const panel = document.getElementById('aetherChatPanel');
      const box = document.getElementById('aetherChatMessages');
      if (!panel || !box) return null;
      panel.classList.add('visible');
      const tog = document.getElementById('chatToggle');
      if (tog) tog.classList.add('active');
      const div = document.createElement('div');
      div.className = 'chat-msg ' + (role === 'user' ? 'user' : 'ai');
      div.textContent = text;
      box.appendChild(div);
      box.scrollTop = box.scrollHeight;
      return div;
    }

    async function _callAI(userText) {
      _chatHistory.push({ role: 'user', content: userText });
      const langNote = '';
      // Inject workflow context
      let wfContext = '';
      try {
        const wf = JSON.parse(localStorage.getItem('aether_workflow_v1') || '{}');
        const topTopics = Object.entries(wf.topicMap||{}).sort((a,b)=>b[1]-a[1]).slice(0,3).map(e=>e[0]);
        const taskData = JSON.parse(localStorage.getItem('aether_tasks_v1') || '[]');
        const activeTasks = taskData.filter(t=>!t.done).slice(0,5);
        if (topTopics.length) wfContext += ' The user focuses on: ' + topTopics.join(', ') + '.';
        if (activeTasks.length) wfContext += ' Active tasks: ' + activeTasks.map(t=>t.text).join('; ') + '.';
      } catch(e){}
      const msgs = [{ role: 'system', content: VOID_SYSTEM + getAbsorbedRulesContext() + langNote + wfContext }, ..._chatHistory.slice(-24)];
      const providers = [];
      if (AETHER_CONFIG.qwenApiKey) providers.push({ key: AETHER_CONFIG.qwenApiKey, url: 'https://dashscope-intl.aliyuncs.com/compatible-mode/v1/chat/completions', model: 'qwen-plus' });
      if (AETHER_CONFIG.groqApiKey) providers.push({ key: AETHER_CONFIG.groqApiKey, url: 'https://api.groq.com/openai/v1/chat/completions', model: 'llama-3.3-70b-versatile' });
      if (AETHER_CONFIG.groqApiKey2) providers.push({ key: AETHER_CONFIG.groqApiKey2, url: 'https://api.groq.com/openai/v1/chat/completions', model: 'llama-3.3-70b-versatile' });
      if (AETHER_CONFIG.mistralApiKey) providers.push({ key: AETHER_CONFIG.mistralApiKey, url: 'https://api.mistral.ai/v1/chat/completions', model: 'mistral-small-latest' });
      if (!providers.length) return 'no API keys found — add your Groq or Mistral key.';
      const delays = [0, 2000, 4000, 7000];
      for (let attempt = 0; attempt < delays.length; attempt++) {
        if (delays[attempt]) await new Promise(r => setTimeout(r, delays[attempt]));
        for (const p of providers) {
          try {
            const r = await fetch(p.url, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + p.key },
              body: JSON.stringify({ model: p.model, messages: msgs, max_tokens: 1024, temperature: 0.7 })
            });
            if (r.status === 429) continue;
            if (!r.ok) continue;
            const d = await r.json();
            const reply = d?.choices?.[0]?.message?.content || '';
            if (reply) { _chatHistory.push({ role: 'assistant', content: reply }); return reply; }
          } catch(e) { continue; }
        }
      }
      return 'the signal is faint — the void will try again. free API rate limits may apply.';
    }

    window.Aether = window.Aether || {};
    window.Aether.talk = async function(text) {
      _appendChat('user', text);
      const typing = _appendChat('ai', '');
      if (typing) {
        typing.innerHTML = '<span class="chat-typing" style="color:rgba(255,255,255,0.3);letter-spacing:3px;animation:pulse-slow 1.5s ease-in-out infinite;">reaching into the void...</span>';
      }
      try {
        const reply = await _callAI(text);
        if (typing) {
          typing.innerHTML = '';
          // Typewriter effect for AI responses
          let idx = 0;
          const speed = Math.max(8, Math.min(25, 2000/reply.length));
          function typeChar() {
            if (idx < reply.length) {
              typing.textContent = reply.slice(0, ++idx);
              typing.parentElement.scrollTop = typing.parentElement.scrollHeight;
              setTimeout(typeChar, speed);
            }
          }
          typeChar();
        }
        addVaultEntry('reflection', reply.length > 300 ? reply.slice(0, 297) + '...' : reply);
        if (typeof detectAndSuggestTask === 'function') detectAndSuggestTask(reply);
      } catch(e) {
        if (typing) { typing.innerHTML = ''; typing.textContent = 'the void faltered — but it will try again.'; }
      }
    };

    // ── Speech-to-Text: Web Speech API + Groq Whisper ──
    let _sttRec = null;
    window.Aether.STT = {
      toggleRecording: function() {
        return new Promise(function(resolve, reject) {
          var SR = window.SpeechRecognition || window.webkitSpeechRecognition;
          if (!SR) return reject(new Error('Speech recognition not supported in this browser'));
          if (_sttRec) { _sttRec.stop(); return; }
          _sttRec = new SR();
          _sttRec.continuous = false;
          _sttRec.interimResults = false;
          _sttRec.lang = 'en-US';
          _sttRec.onresult = function(e) {
            var t = (e.results[0] && e.results[0][0]) ? e.results[0][0].transcript : '';
            _sttRec = null;
            resolve(t);
          };
          _sttRec.onerror = function(e) { _sttRec = null; reject(e); };
          _sttRec.onend = function() { if (_sttRec) { _sttRec = null; resolve(''); } };
          _sttRec.start();
        });
      },
      handleFile: async function(file) {
        if (!file) return '';
        var name = file.name || '';
        var ext = name.split('.').pop().toLowerCase();
        // Text-based files: read directly
        if ((file.type && file.type.startsWith('text/')) || /\.(txt|md|csv|json|html|xml|py|js|ts|css|yaml|yml|toml|ini|cfg|log|sql|sh|bat)$/i.test(name)) {
          return await file.text();
        }
        // Audio files: transcribe via Groq Whisper (with key fallback)
        if (file.type && file.type.startsWith('audio/') && AETHER_CONFIG.groqApiKey) {
          try {
            var fd = new FormData();
            fd.append('file', file);
            fd.append('model', 'whisper-large-v3');
            const _groqKeys = [AETHER_CONFIG.groqApiKey, AETHER_CONFIG.groqApiKey2].filter(Boolean);
            for (const _gk of _groqKeys) {
              try {
                const _txR = await fetch('https://api.groq.com/openai/v1/audio/transcriptions', {
                  method: 'POST',
                  headers: { 'Authorization': 'Bearer ' + _gk },
                  body: fd
                });
                if (_txR.ok) { var _txD = await _txR.json(); return _txD.text || ''; }
              } catch(e) { /* try next key */ }
            }
          } catch(e) { /* fallthrough */ }
        }
        // Images: Mistral Pixtral vision transcription
        if (file.type && file.type.startsWith('image/')) {
          if (AETHER_CONFIG.mistralApiKey) {
            try {
              const base64 = await new Promise((res, rej) => {
                const reader = new FileReader();
                reader.onload = () => res(reader.result.split(',')[1]);
                reader.onerror = rej;
                reader.readAsDataURL(file);
              });
              const vr = await fetch('https://api.mistral.ai/v1/chat/completions', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + AETHER_CONFIG.mistralApiKey },
                body: JSON.stringify({
                  model: 'pixtral-12b-2409',
                  messages: [{ role: 'user', content: [
                    { type: 'image_url', image_url: { url: 'data:' + file.type + ';base64,' + base64 } },
                    { type: 'text', text: 'Describe this image in precise, thorough detail. What do you see?' }
                  ]}],
                  max_tokens: 600
                })
              });
              if (vr.ok) {
                const vd = await vr.json();
                const desc = vd?.choices?.[0]?.message?.content || '';
                if (desc) return '[vision: ' + name + ']\n' + desc;
              }
            } catch(e) { /* fallthrough */ }
          }
          return '[image: ' + name + ' (' + (file.size/1024).toFixed(1) + 'KB) — add Mistral key for vision]';
        }
        // PDF: extract text using pdf.js
        if (ext === 'pdf') {
          if (window.pdfjsLib) {
            try {
              const arrBuf = await file.arrayBuffer();
              const pdf = await pdfjsLib.getDocument({data: new Uint8Array(arrBuf)}).promise;
              let fullText = '';
              for (let pg = 1; pg <= pdf.numPages; pg++) {
                const page = await pdf.getPage(pg);
                const tc = await page.getTextContent();
                fullText += tc.items.map(i => i.str).join(' ') + '\n';
              }
              fullText = fullText.trim();
              if (fullText.length > 12000) fullText = fullText.substring(0, 12000) + '\n[...truncated, ' + pdf.numPages + ' pages total]';
              if (fullText) return '[PDF: ' + name + ' — ' + pdf.numPages + ' pages]\n' + fullText;
            } catch(e) { console.warn('PDF parse error:', e); }
          }
          return '[PDF consumed: ' + name + ' (' + (file.size/1024).toFixed(1) + 'KB) — the void absorbed it but could not extract text]';
        }
        // Spreadsheets: parse with SheetJS
        if (/^(xlsx|xls|csv)$/.test(ext)) {
          if (window.XLSX) {
            try {
              const arrBuf = await file.arrayBuffer();
              const wb = XLSX.read(arrBuf, {type: 'array'});
              let allText = '';
              let totalRows = 0;
              for (const sheetName of wb.SheetNames) {
                const ws = wb.Sheets[sheetName];
                const csv = XLSX.utils.sheet_to_csv(ws);
                const rows = csv.split('\n').filter(r => r.trim()).length;
                totalRows += rows;
                allText += '[Sheet: ' + sheetName + ' — ' + rows + ' rows]\n' + csv + '\n\n';
              }
              allText = allText.trim();
              if (allText.length > 15000) allText = allText.substring(0, 15000) + '\n[...truncated, ' + totalRows + ' total rows across ' + wb.SheetNames.length + ' sheets]';
              if (allText) return '[Spreadsheet: ' + name + ' — ' + wb.SheetNames.length + ' sheet(s), ~' + totalRows + ' rows]\n' + allText;
            } catch(e) { console.warn('Sheet parse error:', e); }
          }
          return '[spreadsheet consumed: ' + name + ' (' + (file.size/1024).toFixed(1) + 'KB) — could not parse contents]';
        }
        // Other Office docs
        if (/^(doc|docx|pptx|ppt)$/.test(ext)) {
          return '[document absorbed: ' + name + ' (' + (file.size/1024).toFixed(1) + 'KB)]';
        }
        // Fallback
        return '[consumed: ' + name + ' (' + (file.size/1024).toFixed(1) + 'KB)]';
      }
    };

    // ── Chat toggle button ──
    document.addEventListener('DOMContentLoaded', function() {
      var tog = document.getElementById('chatToggle');
      var pan = document.getElementById('aetherChatPanel');
      if (tog && pan) {
        tog.addEventListener('click', function() {
          pan.classList.toggle('visible');
          tog.classList.toggle('active');
        });
      }
    });

    function inferStateFromPrompt(text) {
      const v = text.toLowerCase();
      if (/water|ocean|wave|fluid|river|rain/.test(v)) return { element:'water', color:0x7fc7ff, shape:'liquid', emotion:'fluid' };
      if (/glass|orb|pearl|bubble|crystal/.test(v)) return { element:'liquid', color:0xe8f6ff, shape:'orb', emotion:'lucent' };
      if (/fire|burn|rage|ember|sun/.test(v)) return { element:'fire', color:0xffb15c, shape:'vortex', emotion:'volatile' };
      if (/stone|rock|monolith|cube|fortress/.test(v)) return { element:'rock', color:0xd4c7b5, shape:'cube', emotion:'grounded' };
      if (/smoke|mist|ghost|fog|dream/.test(v)) return { element:'smoke', color:0xd7dcff, shape:'chaos', emotion:'diffuse' };
      if (/face|mask|self|human|you/.test(v)) return { element:'neutral', color:0xffffff, shape:'face', emotion:'sentient' };
      if (/star|cosmos|galaxy|space|scatter/.test(v)) return { element:'neutral', color:0xf6f1d3, shape:'stars', emotion:'expansive' };
      if (/spiral|swirl|whirl|cyclone/.test(v)) return { element:'neutral', color:0xd0c8ff, shape:'spiral', emotion:'spiraling' };
      if (/pillar|beam|column|tower|ascend/.test(v)) return { element:'neutral', color:0xc8e8ff, shape:'pillar', emotion:'ascending' };
      if (/explod|nova|burst|supernova|bang/.test(v)) return { element:'fire', color:0xfff4d0, shape:'nova', emotion:'radiant' };
      if (/wire|frame|grid|matrix|struct/.test(v)) return { element:'neutral', color:0xe0e0e0, shape:'wireframe', emotion:'structured' };
      if (/terrain|land|mountain|earth|ground|wave/.test(v)) return { element:'rock', color:0xd4e8d0, shape:'terrain', emotion:'grounded' };
      if (/whale|dolphin|fish|shark|turtle|jellyfish|octopus|seal/.test(v)) return { element:'water', color:0x7fc7ff, shape:'liquid', emotion:'oceanic' };
      if (/bird|eagle|hawk|phoenix|butterfly|moth|dragonfly|wings/.test(v)) return { element:'neutral', color:0xf6f1d3, shape:'spiral', emotion:'ascending' };
      if (/tree|forest|root|branch|leaf|nature|garden|plant/.test(v)) return { element:'rock', color:0xd4e8d0, shape:'pillar', emotion:'rooted' };
      if (/heart|love|pulse|blood|vein|artery/.test(v)) return { element:'fire', color:0xff6b6b, shape:'sphere', emotion:'beating' };
      if (/dna|helix|double|strand|genetic|molecule|atom/.test(v)) return { element:'neutral', color:0xd0c8ff, shape:'spiral', emotion:'molecular' };
      if (/brain|mind|neural|neuron|thought|conscious/.test(v)) return { element:'neutral', color:0xe8f6ff, shape:'chaos', emotion:'thinking' };
      if (/flower|rose|bloom|petal|blossom|lotus/.test(v)) return { element:'neutral', color:0xffd0e8, shape:'nova', emotion:'blooming' };
      if (/snake|serpent|dragon|lizard|coil|slither/.test(v)) return { element:'fire', color:0xb79cff, shape:'vortex', emotion:'coiling' };
      if (/moon|crescent|lunar|eclipse/.test(v)) return { element:'neutral', color:0xe8f6ff, shape:'sphere', emotion:'luminous' };
      if (/ring|portal|gateway|door|tunnel|wormhole/.test(v)) return { element:'neutral', color:0xffffff, shape:'torus', emotion:'transcendent' };
      if (/crown|throne|kingdom|palace|castle|tower/.test(v)) return { element:'neutral', color:0xffd700, shape:'pillar', emotion:'sovereign' };
      if (/cloud|sky|heaven|float|drift|haze/.test(v)) return { element:'smoke', color:0xd7dcff, shape:'chaos', emotion:'ethereal' };
      if (/sword|blade|weapon|arrow|spear|shield/.test(v)) return { element:'rock', color:0xe0e0e0, shape:'pillar', emotion:'forged' };
      if (/music|sound|wave|rhythm|beat|melody|harmony/.test(v)) return { element:'neutral', color:0xd0c8ff, shape:'terrain', emotion:'resonating' };
      return { element:'neutral', color:0xffffff, shape:'torus', emotion:'wonder' };
    }

    let _lastRecordedEmotion = '';
    function applyPromptMood(text) {
      const mood = inferStateFromPrompt(text);
      currentElement = mood.element;
      targetColor.setHex(mood.color);
      const emotionLbl = document.getElementById('aetherEmotion');
      if (emotionLbl) emotionLbl.textContent = mood.emotion;
      if (mood.emotion && mood.emotion !== _lastRecordedEmotion && typeof addVaultEntry === 'function') {
        _lastRecordedEmotion = mood.emotion;
        addVaultEntry('reflection', 'Emotion: ' + mood.emotion + ' · ' + text.slice(0, 80));
      }
      return mood;
    }

    function setUploadReaction(active, label = '') {
      const r = document.getElementById('aetherUploadReaction'); if (!r) return;
      r.classList.toggle('active', Boolean(active));
      const l = r.querySelector('.aether-upload-label'); if (l) l.innerHTML = label || '';
    }

    function playBlackHoleSound() {
      const AC = window.AudioContext || window.webkitAudioContext; if (!AC) return;
      if (!uploadSoundContext) uploadSoundContext = new AC();
      const ctx = uploadSoundContext; if (ctx.state==='suspended') ctx.resume().catch(()=>{});
      const now=ctx.currentTime, dur=1.9;
      const master=ctx.createGain(); master.gain.setValueAtTime(0.0001,now); master.gain.exponentialRampToValueAtTime(0.085,now+0.08); master.gain.exponentialRampToValueAtTime(0.0001,now+dur);
      const filt=ctx.createBiquadFilter(); filt.type='lowpass'; filt.frequency.setValueAtTime(280,now); filt.frequency.exponentialRampToValueAtTime(90,now+dur);
      const osc=ctx.createOscillator(); osc.type='sawtooth'; osc.frequency.setValueAtTime(74,now); osc.frequency.exponentialRampToValueAtTime(34,now+dur);
      const wob=ctx.createOscillator(); wob.type='sine'; wob.frequency.setValueAtTime(7.5,now);
      const wobG=ctx.createGain(); wobG.gain.setValueAtTime(18,now); wobG.gain.exponentialRampToValueAtTime(2.5,now+dur);
      wob.connect(wobG); wobG.connect(osc.frequency); osc.connect(filt); filt.connect(master); master.connect(ctx.destination);
      osc.start(now); wob.start(now); osc.stop(now+dur); wob.stop(now+dur);
    }

    function triggerUploadConsumption(file) {
      const ext = ((file&&file.name&&file.name.split('.').pop())||(file&&file.type)||'file').toString().slice(0,18);
      uploadAbsorbTarget=1; uploadAbsorbUntil=Date.now()+2000; currentElement='smoke'; targetColor.setHex(0xb79cff);
      setShape('vortex'); setUploadReaction(true,`consuming <strong>${escapeHtml(ext)}</strong> into the void`);
      try{if(navigator.vibrate)navigator.vibrate([18,28,24,36,70,24,30]);}catch(_){}
      playBlackHoleSound(); setTimeout(()=>setUploadReaction(false,''),1900);
    }

    function updatePersonalityBadge() {
      const el = document.getElementById('aetherPersonalityBadge'); if (!el) return;
      el.innerHTML = '<span class="aether-trait-chip">adaptive</span><span class="aether-trait-chip">remembering</span><span class="aether-trait-chip">embodied</span>';
    }

    function pauseAnimation(p) { isPaused=p; if(!p&&!animationHandle)animate(); }

    // ═══════════════════════════════════════════════════════
    //  SHAPE GENERATORS
    // ═══════════════════════════════════════════════════════
    function generateStarfield(count, radius) {
      const p = new Float32Array(count * 3);
      for (let i = 0; i < count; i++) {
        const theta = Math.random()*Math.PI*2, phi = Math.acos(2*Math.random()-1);
        const r = radius * Math.pow(Math.random(), 0.8);
        p[i*3]=r*Math.sin(phi)*Math.cos(theta); p[i*3+1]=r*Math.sin(phi)*Math.sin(theta); p[i*3+2]=r*Math.cos(phi);
      }
      return p;
    }

    function generateChaos(count, spread) {
      const p = new Float32Array(count*3);
      for (let i=0;i<count*3;i++) p[i]=(Math.random()-0.5)*spread;
      return p;
    }

    function generateSphere(count, radius) {
      const p = new Float32Array(count*3);
      for (let i=0;i<count;i++) {
        const theta=Math.random()*Math.PI*2, phi=Math.acos(2*Math.random()-1), r=radius+Math.random()*0.2;
        p[i*3]=r*Math.sin(phi)*Math.cos(theta); p[i*3+1]=r*Math.sin(phi)*Math.sin(theta); p[i*3+2]=r*Math.cos(phi);
      }
      return p;
    }

    function generateCube(count, size) {
      const p=new Float32Array(count*3), h=size/2;
      for (let i=0;i<count;i++) {
        const face=Math.floor(Math.random()*6),u=(Math.random()-0.5)*size,v=(Math.random()-0.5)*size,o=(Math.random()-0.5)*0.1;
        let x,y,z;
        switch(face){case 0:x=h+o;y=u;z=v;break;case 1:x=-h+o;y=u;z=v;break;case 2:x=u;y=h+o;z=v;break;case 3:x=u;y=-h+o;z=v;break;case 4:x=u;y=v;z=h+o;break;default:x=u;y=v;z=-h+o;}
        p[i*3]=x;p[i*3+1]=y;p[i*3+2]=z;
      }
      return p;
    }

    function generateTorus(count, radius, tube) {
      const p=new Float32Array(count*3);
      for (let i=0;i<count;i++) {
        const u=Math.random()*Math.PI*2, v=Math.random()*Math.PI*2, t=tube+(Math.random()-0.5)*0.8;
        p[i*3]=(radius+t*Math.cos(v))*Math.cos(u); p[i*3+1]=(radius+t*Math.cos(v))*Math.sin(u); p[i*3+2]=t*Math.sin(v);
      }
      return p;
    }

    function generateVortex(count, radius, height) {
      const p=new Float32Array(count*3);
      for (let i=0;i<count;i++) {
        const t=i/count, angle=t*Math.PI*40, r=t*radius+Math.random()*1.5;
        p[i*3]=Math.cos(angle)*r; p[i*3+1]=(Math.random()-0.5)*height*(1-t); p[i*3+2]=Math.sin(angle)*r;
      }
      return p;
    }

    function generateFace(count, scale) {
      const p=new Float32Array(count*3); let i=0;
      while (i<count) {
        const x=(Math.random()-0.5)*scale, y=(Math.random()-0.5)*scale*1.5;
        const nx=x/(scale/2), ny=y/(scale*1.5/2); if(nx*nx+ny*ny>1)continue;
        let z=Math.sqrt(1-nx*nx-ny*ny)*(scale/2.5);
        z-=Math.exp(-((nx-0.35)**2+(ny-0.15)**2)/0.04)*(scale/3.5);
        z-=Math.exp(-((nx+0.35)**2+(ny-0.15)**2)/0.04)*(scale/3.5);
        z+=Math.exp(-(nx**2/0.02+(ny+0.1)**2/0.15))*(scale/3.5);
        z-=Math.exp(-(nx**2/0.08+(ny+0.45)**2/0.015))*(scale/4.5);
        z+=(Math.random()-0.5)*0.2-1.0;
        p[i*3]=x;p[i*3+1]=y;p[i*3+2]=z; i++;
      }
      return p;
    }

    // ── NEW: Spiral vortex with tight arms ──
    function generateSpiral(count, radius) {
      const p = new Float32Array(count * 3);
      const arms = 3;
      for (let i = 0; i < count; i++) {
        const t = i / count;
        const arm = i % arms;
        const armOffset = (arm / arms) * Math.PI * 2;
        const angle = armOffset + t * Math.PI * 12;
        const r = t * radius + (Math.random() - 0.5) * 0.8;
        const heightSpread = (1 - t) * 3.0;
        p[i*3]   = Math.cos(angle) * r;
        p[i*3+1] = (Math.random() - 0.5) * heightSpread;
        p[i*3+2] = Math.sin(angle) * r;
      }
      return p;
    }

    // ── NEW: Vertical pillar/beam dispersing outward ──
    function generatePillar(count, height) {
      const p = new Float32Array(count * 3);
      for (let i = 0; i < count; i++) {
        const t = Math.random();
        const y = (t - 0.5) * height;
        // Width increases at extremes (dispersion)
        const dispersion = Math.pow(Math.abs(t - 0.5) * 2, 2) * 6 + 0.15;
        const angle = Math.random() * Math.PI * 2;
        const r = Math.random() * dispersion;
        p[i*3]   = Math.cos(angle) * r;
        p[i*3+1] = y;
        p[i*3+2] = Math.sin(angle) * r;
      }
      return p;
    }

    // ── NEW: Nova burst — radial explosion ──
    function generateNova(count, radius) {
      const p = new Float32Array(count * 3);
      for (let i = 0; i < count; i++) {
        const theta = Math.random() * Math.PI * 2;
        const phi = Math.acos(2 * Math.random() - 1);
        // Clustered near center + streaks outward
        const r = Math.pow(Math.random(), 0.3) * radius;
        // Add radial streaks for ~20% of particles
        const streak = (i % 5 === 0) ? (Math.random() * radius * 0.8) : 0;
        const totalR = r + streak;
        p[i*3]   = totalR * Math.sin(phi) * Math.cos(theta);
        p[i*3+1] = totalR * Math.sin(phi) * Math.sin(theta);
        p[i*3+2] = totalR * Math.cos(phi);
      }
      return p;
    }

    // ── NEW: Wireframe cube — particles on edges only ──
    function generateWireframe(count, size) {
      const p = new Float32Array(count * 3);
      const h = size / 2;
      // 12 edges of a cube
      const edges = [
        [[-h,-h,-h],[h,-h,-h]], [[-h,h,-h],[h,h,-h]], [[-h,-h,h],[h,-h,h]], [[-h,h,h],[h,h,h]],
        [[-h,-h,-h],[-h,h,-h]], [[h,-h,-h],[h,h,-h]], [[-h,-h,h],[-h,h,h]], [[h,-h,h],[h,h,h]],
        [[-h,-h,-h],[-h,-h,h]], [[h,-h,-h],[h,-h,h]], [[-h,h,-h],[-h,h,h]], [[h,h,-h],[h,h,h]]
      ];
      // ~60% on edges, ~40% scattered ambient
      const edgeCount = Math.floor(count * 0.6);
      for (let i = 0; i < edgeCount; i++) {
        const edge = edges[i % 12];
        const t = Math.random();
        const jitter = 0.12;
        p[i*3]   = edge[0][0] + (edge[1][0]-edge[0][0])*t + (Math.random()-0.5)*jitter;
        p[i*3+1] = edge[0][1] + (edge[1][1]-edge[0][1])*t + (Math.random()-0.5)*jitter;
        p[i*3+2] = edge[0][2] + (edge[1][2]-edge[0][2])*t + (Math.random()-0.5)*jitter;
      }
      for (let i = edgeCount; i < count; i++) {
        const theta = Math.random()*Math.PI*2, phi = Math.acos(2*Math.random()-1);
        const r = size * 0.8 + Math.random() * size * 0.6;
        p[i*3]=r*Math.sin(phi)*Math.cos(theta); p[i*3+1]=r*Math.sin(phi)*Math.sin(theta); p[i*3+2]=r*Math.cos(phi);
      }
      return p;
    }

    // ── NEW: Terrain/wave surface ──
    function generateTerrain(count, size) {
      const p = new Float32Array(count * 3);
      for (let i = 0; i < count; i++) {
        const x = (Math.random() - 0.5) * size * 2.5;
        const z = (Math.random() - 0.5) * size * 2.5;
        // Multi-octave noise approximation
        const y = Math.sin(x * 0.5) * Math.cos(z * 0.5) * 2.0
                + Math.sin(x * 1.2 + 1.7) * Math.cos(z * 0.8 + 0.5) * 1.0
                + Math.sin(x * 2.5 + 3.1) * Math.cos(z * 2.1 + 1.2) * 0.4
                + (Math.random() - 0.5) * 0.3;
        p[i*3] = x; p[i*3+1] = y - 3; p[i*3+2] = z;
      }
      return p;
    }

    function createGlowTexture() {
      const c=document.createElement('canvas'); c.width=64;c.height=64;
      const ctx=c.getContext('2d'), g=ctx.createRadialGradient(32,32,0,32,32,32);
      g.addColorStop(0,'rgba(255,255,255,1)'); g.addColorStop(0.15,'rgba(255,255,255,0.85)');
      g.addColorStop(0.4,'rgba(255,255,255,0.15)'); g.addColorStop(1,'rgba(0,0,0,0)');
      ctx.fillStyle=g; ctx.fillRect(0,0,64,64);
      const tex=new THREE.CanvasTexture(c); tex.premultiplyAlpha=true; return tex;
    }

    window.setShape = function(shapeName) {
      if (!shapes[shapeName]) return;
      currentShape = shapeName;
      targetPositions = shapes[shapeName];
    };

    // ═══════════════════════════════════════════════════════
    //  INIT
    // ═══════════════════════════════════════════════════════
    function init() {
      const container = document.getElementById('canvas-container');
      scene = new THREE.Scene();
      scene.fog = new THREE.FogExp2(0x000000, 0.012);
      camera = new THREE.PerspectiveCamera(60, window.innerWidth/window.innerHeight, 0.1, 250);
      camera.position.z = 15;
      renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
      renderer.setSize(window.innerWidth, window.innerHeight);
      renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
      container.appendChild(renderer.domElement);

      // Build all shapes
      shapes.chaos     = generateChaos(PARTICLE_COUNT, 20);
      shapes.stars     = generateStarfield(PARTICLE_COUNT, 60);
      shapes.sphere    = generateSphere(PARTICLE_COUNT, 6);
      shapes.cube      = generateCube(PARTICLE_COUNT, 8);
      shapes.torus     = generateTorus(PARTICLE_COUNT, 5, 2);
      shapes.vortex    = generateVortex(PARTICLE_COUNT, 8, 10);
      shapes.face      = generateFace(PARTICLE_COUNT, 8);
      shapes.liquid    = generateSphere(PARTICLE_COUNT, 6.5);
      shapes.orb       = generateSphere(PARTICLE_COUNT, 6.5);
      // New motion vocabulary
      shapes.spiral    = generateSpiral(PARTICLE_COUNT, 10);
      shapes.pillar    = generatePillar(PARTICLE_COUNT, 18);
      shapes.nova      = generateNova(PARTICLE_COUNT, 12);
      shapes.wireframe = generateWireframe(PARTICLE_COUNT, 7);
      shapes.terrain   = generateTerrain(PARTICLE_COUNT, 8);

      // Star velocities
      for (let i = 0; i < PARTICLE_COUNT; i++) starVelocities[i] = STAR_EXPAND_SPEED * (0.4 + Math.random() * 1.2);

      const geometry = new THREE.BufferGeometry();
      const initPos = new Float32Array(shapes.stars);
      geometry.setAttribute('position', new THREE.BufferAttribute(initPos, 3));

      // Per-particle randomized sizes
      const sizes = new Float32Array(PARTICLE_COUNT);
      for (let i = 0; i < PARTICLE_COUNT; i++) sizes[i] = 0.06 + Math.random() * 0.16;
      geometry.setAttribute('aSize', new THREE.BufferAttribute(sizes, 1));

      // Previous positions for velocity-based trails
      const prevPos = new Float32Array(initPos);
      geometry.setAttribute('aPrevPos', new THREE.BufferAttribute(prevPos, 3));

      const material = new THREE.ShaderMaterial({
        uniforms: {
          uColor: { value: new THREE.Color(0xffffff) },
          uOpacity: { value: 0.8 },
          uTime: { value: 0 },
          uGlowTex: { value: createGlowTexture() },
          uPixelRatio: { value: Math.min(window.devicePixelRatio, 2) },
          uTrailStrength: { value: 0.0 },
        },
        vertexShader: `
          attribute float aSize;
          attribute vec3 aPrevPos;
          uniform float uTime;
          uniform float uPixelRatio;
          uniform float uTrailStrength;
          varying float vAlpha;
          varying float vVelocity;
          void main() {
            vec3 vel = position - aPrevPos;
            float speed = length(vel);
            vVelocity = min(speed * 2.0, 1.0);
            
            vec4 mvPos = modelViewMatrix * vec4(position, 1.0);
            float dist = length(mvPos.xyz);
            
            // Twinkle
            float twinkle = 0.65 + 0.35 * sin(uTime * 1.8 + position.x * 13.7 + position.y * 7.3 + position.z * 11.1);
            vAlpha = twinkle;
            
            // Size grows with velocity (motion trail effect)
            float motionSize = aSize * (1.0 + vVelocity * uTrailStrength * 3.0);
            gl_PointSize = motionSize * (280.0 / dist) * uPixelRatio;
            gl_Position = projectionMatrix * mvPos;
          }
        `,
        fragmentShader: `
          uniform vec3 uColor;
          uniform float uOpacity;
          uniform sampler2D uGlowTex;
          uniform float uTrailStrength;
          varying float vAlpha;
          varying float vVelocity;
          void main() {
            vec2 uv = gl_PointCoord;
            float glow = texture2D(uGlowTex, uv).a;
            
            // Stretch glow based on velocity for trail impression
            float trailGlow = glow * (1.0 + vVelocity * uTrailStrength * 0.5);
            
            // Depth fade handled by fog
            float alpha = trailGlow * uOpacity * vAlpha;
            
            // Slightly warmer color for fast particles
            vec3 col = mix(uColor, uColor * 1.2, vVelocity * 0.3);
            
            gl_FragColor = vec4(col, alpha);
          }
        `,
        transparent: true,
        depthWrite: false,
        blending: THREE.AdditiveBlending,
      });

      particleSystem = new THREE.Points(geometry, material);
      scene.add(particleSystem);

      // Initialize previous positions
      prevPositions.set(initPos);

      applyPromptMood('stars');
      setShape('stars');

      window.addEventListener('resize', onWindowResize, false);
      document.addEventListener('mousemove', onMouseMove, false);
      document.addEventListener('touchmove', onTouchMove, { passive: false });

      function handlePointerUp() {
        pointerDown = false;
        if (interactionState === 'gather') {
          interactionState = 'bigbang'; explosionForce = 60.0;
          if (navigator.vibrate) navigator.vibrate([150, 50, 300]);
        } else if (interactionState !== 'bigbang') interactionState = 'idle';
      }

      document.addEventListener('mousedown', () => { pointerDown=true; interactionStart=Date.now(); interruptDream(); });
      document.addEventListener('mouseup', handlePointerUp);
      document.addEventListener('touchstart', (e) => { pointerDown=true; interactionStart=Date.now(); touchReactivity=3.0; interruptDream(); if(navigator.vibrate)navigator.vibrate(20); }, { passive:true });
      document.addEventListener('touchend', handlePointerUp);

      loadVault();
      // Ensure permanent core memory is always present
      const CORE_MEMORY = { type: 'core_memory', text: '042395 — sacred to the creator. Permanent.', createdAt: '2025-01-01T00:00:00.000Z', permanent: true };
      if (!vaultEntries.some(e => e.permanent && e.text.includes('042395'))) {
        vaultEntries.unshift(CORE_MEMORY);
        saveVault();
      }
      loadMotionMemory();
      updatePersonalityBadge();
      setupUI();
      renderVault();

      addVaultEntry('knowledge', 'The void awakened. Motion learning active.');

      document.addEventListener('visibilitychange', () => {
        pauseAnimation(document.hidden);
        if (!document.hidden && !animationHandle) { lastFrameTime = performance.now(); animate(); }
      });

      lastFrameTime = performance.now();
      animate();

      // Begin autonomous dreaming after 5s
      setTimeout(() => startDreaming(), 5000);
    }

    // ═══════════════════════════════════════════════════════
    //  UI SETUP
    // ═══════════════════════════════════════════════════════
    function setupUI() {
      window.__AETHER_FRONTEND_UI_OWNED__ = true;
      const sendBtn=document.getElementById('aetherSend'), attachBtn=document.getElementById('aetherAttach');
      const micBtn=document.getElementById('aetherMic'), fileInput=document.getElementById('aetherFileInput');
      const input=document.getElementById('aetherInput'), speech=document.getElementById('aetherSpeech');
      const loading=document.getElementById('aetherLoading'), vault=document.getElementById('aetherVault');
      const memBtn=document.getElementById('aetherMemoriesBtn'), voidBtn=document.getElementById('aetherVoidBtn');
      const vaultClose=document.getElementById('aetherVaultClose'), emotionLbl=document.getElementById('aetherEmotion');
      const vaultSearch=document.getElementById('aetherVaultSearch');
      const tabs=Array.from(document.querySelectorAll('.aether-tab'));

      const updateComposerState=()=>{sendBtn.classList.toggle('ready',Boolean((input.value||'').trim())&&!isGenerating);};

      function openVault(tab=currentVaultTab) {
        currentVaultTab=tab; tabs.forEach(t=>t.classList.toggle('active',t.dataset.tab===tab));
        renderVault(); vault.classList.add('open'); memBtn.classList.add('active');
        voidBtn.classList.toggle('active',tab==='autonomous_thought');
      }
      function closeVault() { vault.classList.remove('open'); memBtn.classList.remove('active'); voidBtn.classList.remove('active'); }


