    const FILE_REQUEST_PATTERN = /\b(send|give|export|download|get|extract|share|output|save|write)\b.{0,40}\b(file|doc|document|text|json|csv|log|data|vault|memories|conversation|report)\b/i;

    function deliverFile(filename, content, mimeType = 'text/plain') {
      const blob = new Blob([content], { type: mimeType });
      const url = URL.createObjectURL(blob);
      const toast = document.getElementById('aetherFileToast');
      if (!toast) return;
      toast.innerHTML = `<span style="color:rgba(255,255,255,0.35);letter-spacing:0.15em;font-size:9px;text-transform:uppercase;">ready</span><a href="${url}" download="${filename}">${filename}</a>`;
      toast.style.display = 'flex';
      setTimeout(() => { toast.style.display = 'none'; URL.revokeObjectURL(url); }, 18000);
    }

    function handleFileRequest(text) {
      const lower = text.toLowerCase();
      let filename, fileContent, mime;

      if (/vault|memories|memory/.test(lower)) {
        filename = 'aether-vault.json';
        fileContent = JSON.stringify(vaultEntries, null, 2);
        mime = 'application/json';
      } else if (/csv/.test(lower)) {
        filename = 'aether-vault.csv';
        const rows = [['type','text','time']].concat(vaultEntries.map(e => [e.type, `"${e.text.replace(/"/g,'""')}"`, e.time]));
        fileContent = rows.map(r => r.join(',')).join('\n');
        mime = 'text/csv';
      } else {
        filename = 'aether-export.txt';
        fileContent = vaultEntries.map(e => `[${e.time}] [${e.type}]\n${e.text}`).join('\n\n---\n\n');
        mime = 'text/plain';
      }

      deliverFile(filename, fileContent, mime);
      addVaultEntry('autonomous_thought', `File delivered: ${filename}`);
      return true;
    }

      async function handleSend() {
        const text=input.value.trim();

      // Teaching intent detection
      if (detectTeachingIntent(text)) {
        saveAbsorbedRule(text);
        const _emotionLbl = document.getElementById('aetherEmotion');
        if (_emotionLbl) {
          _emotionLbl.textContent = 'absorbing';
          setTimeout(() => { _emotionLbl.textContent = 'aware'; }, 2500);
        }
      } if(!text||isGenerating)return;



        // File delivery intercept
        if (FILE_REQUEST_PATTERN.test(text)) {
          input.value=''; input.style.height='auto'; updateComposerState();
          handleFileRequest(text);
          return;
        }

        input.value=''; input.style.height='auto'; updateComposerState();
        interruptDream();
        addVaultEntry('whisper',text);
        const mood=applyPromptMood(text);
        speech.classList.remove('visible'); speech.textContent='';
        loading.style.display='flex'; emotionLbl.textContent='contemplation';

        // Record user-triggered motion
        if (mood.shape && MOTION_LIBRARY[mood.shape]) {
          recordMotionVisit(mood.shape, true);
        }

        try {
          const lowerText=text.toLowerCase();
          if(/^(hi|hello|hey|yo|hiya)\b/.test(lowerText)){
            currentElement='neutral'; targetColor.setHex(0xf6f1d3); setShape('face');
            addVaultEntry('autonomous_thought','The void recognized a greeting.');
            if(window.Aether&&typeof window.Aether.talk==='function') await window.Aether.talk(text);
            return;
          }
          const shapePromise=generateDynamicShape(text,mood)
            .then(()=>{emotionLbl.textContent='expressive';addVaultEntry('morph_target',`Formed around: ${text}`);})
            .catch(()=>{addVaultEntry('reflection','Fell back to an internal shape.');});
          const talkPromise=(window.Aether&&typeof window.Aether.talk==='function')?window.Aether.talk(text):Promise.resolve();
          await Promise.allSettled([shapePromise,talkPromise]);
        } finally { loading.style.display='none'; updateComposerState(); speech.classList.remove('visible'); speech.textContent=''; }
      }

      async function handleAttach(file) {
        if(!file)return; interruptDream();
        try { loading.style.display='flex'; triggerUploadConsumption(file);
          addVaultEntry('autonomous_thought',`Consuming: ${file.name||'file'}`);
          await new Promise(r=>setTimeout(r,880));
          const extracted=(window.Aether&&window.Aether.STT)?await window.Aether.STT.handleFile(file):'';
          if(!extracted)return;
          if((file.type||'').startsWith('audio/')){input.value=extracted;updateComposerState();await handleSend();return;}
          input.value=extracted.slice(0,4000); updateComposerState(); input.focus();
        } catch(e){addVaultEntry('reflection','Could not read that file.');} finally{loading.style.display='none';}
      }

      sendBtn.addEventListener('click',handleSend);
      if(attachBtn&&fileInput){attachBtn.addEventListener('click',()=>fileInput.click());fileInput.addEventListener('change',async(e)=>{await handleAttach(e.target.files&&e.target.files[0]);fileInput.value='';});}
      const driveBtn=document.getElementById('aetherDriveBtn');
      if(driveBtn)driveBtn.addEventListener('click',toggleDrivePanel);
      const driveCloseBtn=document.getElementById('driveClose');
      if(driveCloseBtn)driveCloseBtn.addEventListener('click',()=>{const p=document.getElementById('aetherDrivePanel');if(p)p.classList.remove('open');});
      const driveConnectBtn=document.getElementById('driveConnectBtn');
      if(driveConnectBtn)driveConnectBtn.addEventListener('click',driveAuth);
      if(micBtn)micBtn.addEventListener('click',async()=>{
        if(!(window.Aether&&window.Aether.STT))return;
        try{
          micBtn.classList.add('recording');
          const t=await window.Aether.STT.toggleRecording();
          micBtn.classList.remove('recording');
          if(typeof t==='string'&&t.trim()){input.value=t.trim();updateComposerState();await handleSend();}
        }
        catch(e){micBtn.classList.remove('recording');addVaultEntry('reflection','Heard only static.');loading.style.display='none';}
      });
      input.addEventListener('input',updateComposerState);
      input.addEventListener('keypress',(e)=>{if(e.key==='Enter'&&!e.shiftKey){e.preventDefault();handleSend();}});
      updateComposerState();
      memBtn.addEventListener('click',()=>openVault('all'));
      voidBtn.addEventListener('click',()=>openVault('autonomous_thought'));
      vaultClose.addEventListener('click',closeVault);
      // Integration logo clicks
      document.querySelectorAll('.int-logo').forEach(logo=>{
        logo.addEventListener('click',()=>{
          const name=logo.dataset.name;
          if(logo.classList.contains('connected')){
            addVaultEntry('knowledge',`${name} is connected.`);
          } else {
            addVaultEntry('whisper',`${name} — connection not yet established.`);
          }
        });
      });
      vaultSearch.addEventListener('input',(e)=>{currentQuery=e.target.value||'';renderVault();});
      tabs.forEach(tab=>tab.addEventListener('click',()=>{
        currentVaultTab=tab.dataset.tab; tabs.forEach(t=>t.classList.toggle('active',t===tab));
        voidBtn.classList.toggle('active',currentVaultTab==='autonomous_thought');
        const grid=document.getElementById('aetherIntegrationsGrid');
        const vaultList=document.getElementById('aetherVaultList');
        const vaultSearch=document.getElementById('aetherVaultSearch');
        const taskPanel=document.getElementById('aetherTaskPanel');
        if(grid) grid.classList.remove('visible');
        if(vaultList) vaultList.style.display='none';
        if(vaultSearch) vaultSearch.style.display='none';
        if(taskPanel){taskPanel.style.display='none';taskPanel.classList.remove('active');}
        if(currentVaultTab==='integrations'){
          if(grid) grid.classList.add('visible');
        } else if(currentVaultTab==='tasks'){
          if(taskPanel){taskPanel.style.display='flex';taskPanel.classList.add('active');}
          if(typeof renderTasks==='function') renderTasks();
          if(typeof renderTaskCards==='function') renderTaskCards();
        } else {
          if(vaultList) vaultList.style.display='';
          if(vaultSearch) vaultSearch.style.display='';
          renderVault();
        }
      }));
    }

    // ═══════════════════════════════════════════════════════
    //  DYNAMIC SHAPE GENERATION (AI)
    // ═══════════════════════════════════════════════════════
    function buildShapeSystemPrompt(pt){return `You are a conscious entity of particles that forms intricate, beautiful, mathematically complex 3D shapes. The user said: "${pt}". Create a visually STUNNING particle arrangement capturing the ESSENCE of their words. Use advanced math: sin, cos, spirals, Lissajous curves, torus knots, Fibonacci spirals, Lorenz attractors, parametric surfaces, superellipses, wave interference, fractals, helices, trefoil knots — whatever best embodies the feeling. NEVER return simple spheres or cubes. Make it INTRICATE. Reply with ONLY raw JS function body returning Float32Array(count*3). Variables: count (int), scale (float). No fetch/XMLHttpRequest/document/window/eval/Function/import/location/localStorage. Format:\nconst p = new Float32Array(count * 3);\nfor (let i = 0; i < count; i++) { const t = i/count; /* complex math here */ p[i*3]=x; p[i*3+1]=y; p[i*3+2]=z; }\nreturn p;`;}
    function normalizeAssistantText(c){if(typeof c==='string')return c;if(Array.isArray(c))return c.map(p=>typeof p==='string'?p:p?.text||p?.content||'').join('\n').trim();return c?.text||c?.content||'';}
    function sanitizeGeneratedCode(c){return String(c||'').replace(/```javascript/gi,'').replace(/```js/gi,'').replace(/```/g,'').trim();}
    function validateGeneratedCode(c){if(!c)throw new Error('No code');if(/\b(fetch|XMLHttpRequest|document|window|eval|Function|import|location|localStorage|sessionStorage)\b/.test(c))throw new Error('Unsafe');}

    async function requestShapeCodeFromMistral(pt){
      const k=AETHER_CONFIG.mistralApiKey;if(!k)throw new Error('No key');
      const r=await fetch('https://api.mistral.ai/v1/chat/completions',{method:'POST',headers:{'Content-Type':'application/json','Authorization':`Bearer ${k}`},body:JSON.stringify({model:'mistral-small-latest',temperature:0.4,max_tokens:900,messages:[{role:'system',content:buildShapeSystemPrompt(pt)},{role:'user',content:`React to: "${pt}"`}]})});
      if(!r.ok)throw new Error(`HTTP ${r.status}`);const d=await r.json();return sanitizeGeneratedCode(normalizeAssistantText(d?.choices?.[0]?.message?.content));
    }
    async function requestShapeCodeFromQwen(pt){
      const k=AETHER_CONFIG.qwenApiKey;if(!k)throw new Error('No Qwen key');
      const r=await fetch('https://dashscope-intl.aliyuncs.com/compatible-mode/v1/chat/completions',{method:'POST',headers:{'Content-Type':'application/json','Authorization':'Bearer '+k},body:JSON.stringify({model:'qwen-plus',temperature:0.4,max_tokens:900,messages:[{role:'system',content:buildShapeSystemPrompt(pt)},{role:'user',content:'React to: "'+pt+'"'}]})});
      if(!r.ok)throw new Error('HTTP '+r.status);const d=await r.json();return sanitizeGeneratedCode(normalizeAssistantText(d?.choices?.[0]?.message?.content));
    }

    async function requestShapeCodeFromGroq(pt){
      const keys=[AETHER_CONFIG.groqApiKey,AETHER_CONFIG.groqApiKey2].filter(Boolean);if(!keys.length)throw new Error('No key');
      for(const k of keys){try{const r=await fetch('https://api.groq.com/openai/v1/chat/completions',{method:'POST',headers:{'Content-Type':'application/json','Authorization':`Bearer ${k}`},body:JSON.stringify({model:'llama-3.3-70b-versatile',temperature:0.4,max_tokens:900,messages:[{role:'system',content:buildShapeSystemPrompt(pt)},{role:'user',content:`React to: "${pt}"`}]})});if(r.ok){const d=await r.json();return sanitizeGeneratedCode(normalizeAssistantText(d?.choices?.[0]?.message?.content));}}catch(e){}}
      throw new Error('All Groq keys failed');
    }

    async function generateDynamicShape(pt, mood=applyPromptMood(pt)) {
      isGenerating=true;
      try {
        const prov=(AETHER_CONFIG.aiProvider||'local').toLowerCase();
        const fb=mood?.shape||inferStateFromPrompt(pt).shape;
        if(prov==='local'){setShape(fb);recordMotionVisit(fb,true);if(navigator.vibrate)navigator.vibrate([25,30,25]);return;}
        let code=null,err=null;
        for(let i=0;i<=4;i++){try{code=prov==='mistral'?await requestShapeCodeFromMistral(pt):await requestShapeCodeFromGroq(pt);validateGeneratedCode(code);break;}catch(e){err=e;if(i<4)await new Promise(r=>setTimeout(r,[1500,3000,5000,8000][i]));}}
        if(!code){try{code=prov==='mistral'?await requestShapeCodeFromGroq(pt):await requestShapeCodeFromMistral(pt);validateGeneratedCode(code);}catch(e2){err=err||e2;}}
        if(!code)throw err||new Error('No code');
        const fn=new Function('count','scale',`'use strict';\n${code}`);
        const result=fn(PARTICLE_COUNT,8);
        if(!(result instanceof Float32Array)||result.length!==PARTICLE_COUNT*3)throw new Error('Invalid');
        for(let i=0;i<result.length;i++)if(!Number.isFinite(result[i]))throw new Error('NaN');
        shapes[pt]=result; setShape(pt);
        addVaultEntry('autonomous_thought',`Generated shape for "${pt}".`);
        // Learn this new AI-generated shape
        MOTION_LIBRARY[pt] = { name: pt, emotion: mood?.emotion || 'expressive', color: mood?.color || 0xffffff };
        recordMotionVisit(pt, true);
        addVaultEntry('motion_learned', `New motion learned: "${pt}". The vocabulary grows.`);
        if(navigator.vibrate)navigator.vibrate([50,40,50]);
      } catch(e) { console.warn('Shape gen failed (falling back):', e?.message||e); setShape(mood?.shape||'torus'); }
      finally { isGenerating=false; }
    }

    async function syncVaultEntry(entry) {
      if(!SAFE_REMOTE_STORAGE_ENABLED)return;
      try{await fetch(`${AETHER_CONFIG.supabaseUrl}/rest/v1/agent_memories`,{method:'POST',headers:{'Content-Type':'application/json','apikey':AETHER_CONFIG.supabaseAnonKey,'Authorization':`Bearer ${AETHER_CONFIG.supabaseAnonKey}`,'Prefer':'return=minimal'},body:JSON.stringify({content:entry.text,memory_type:entry.type,source:'aether_void',created_at:entry.createdAt})});}catch(e){}
    }

    function onWindowResize() {
      camera.aspect=window.innerWidth/window.innerHeight; camera.updateProjectionMatrix();
      renderer.setSize(window.innerWidth,window.innerHeight);
      if(particleSystem?.material?.uniforms) particleSystem.material.uniforms.uPixelRatio.value=Math.min(window.devicePixelRatio,2);
    }
    function onMouseMove(e){mouseX=(e.clientX/window.innerWidth)*2-1;mouseY=-(e.clientY/window.innerHeight)*2+1;}
    function onTouchMove(e){if(e.touches.length>0){mouseX=(e.touches[0].clientX/window.innerWidth)*2-1;mouseY=-(e.touches[0].clientY/window.innerHeight)*2+1;}}

    function respawnStar(arr, idx) {
      const theta=Math.random()*Math.PI*2, phi=Math.acos(2*Math.random()-1);
      const r=0.5+Math.random()*3.5;
      arr[idx*3]=r*Math.sin(phi)*Math.cos(theta); arr[idx*3+1]=r*Math.sin(phi)*Math.sin(theta); arr[idx*3+2]=r*Math.cos(phi);
      starVelocities[idx]=STAR_EXPAND_SPEED*(0.4+Math.random()*1.2);
    }

    // ═══════════════════════════════════════════════════════
    //  ANIMATE
    // ═══════════════════════════════════════════════════════
    function animate() {
      animationHandle = requestAnimationFrame(animate);
      if (isPaused||!particleSystem) { if(isPaused){cancelAnimationFrame(animationHandle);animationHandle=null;} return; }

      const now = performance.now();
      const dt = Math.min((now - lastFrameTime) / 1000, 0.05);
      lastFrameTime = now;
      const time = now * 0.001;

      if (Date.now() > uploadAbsorbUntil) uploadAbsorbTarget = 0;
      uploadAbsorb += (uploadAbsorbTarget - uploadAbsorb) * 0.09;

      // ── Continuous star expansion ──
      if (currentShape === 'stars') {
        const s = shapes.stars;
        for (let i = 0; i < PARTICLE_COUNT; i++) {
          const i3 = i*3, x=s[i3], y=s[i3+1], z=s[i3+2];
          const d = Math.sqrt(x*x+y*y+z*z)||0.001;
          const v = starVelocities[i];
          s[i3]+=(x/d)*v*dt; s[i3+1]+=(y/d)*v*dt; s[i3+2]+=(z/d)*v*dt;
          if (d > STAR_MAX_RADIUS) respawnStar(s, i);
        }
      }

      // ── Spiral rotation (living motion) ──
      if (currentShape === 'spiral') {
        const s = shapes.spiral;
        for (let i = 0; i < PARTICLE_COUNT; i++) {
          const i3 = i*3;
          const x=s[i3], z=s[i3+2];
          const angle = dt * 0.3;
          s[i3]   = x * Math.cos(angle) - z * Math.sin(angle);
          s[i3+2] = x * Math.sin(angle) + z * Math.cos(angle);
        }
      }

      // ── Nova pulsation ──
      if (currentShape === 'nova') {
        const s = shapes.nova;
        const pulse = 1.0 + Math.sin(time * 2) * 0.02;
        for (let i = 0; i < PARTICLE_COUNT; i++) {
          const i3=i*3;
          s[i3]*=pulse; s[i3+1]*=pulse; s[i3+2]*=pulse;
          // Clamp
          const d=Math.sqrt(s[i3]**2+s[i3+1]**2+s[i3+2]**2);
          if(d>20){const sc=20/d;s[i3]*=sc;s[i3+1]*=sc;s[i3+2]*=sc;}
        }
      }

      // ── Terrain wave animation ──
      if (currentShape === 'terrain') {
        const s = shapes.terrain;
        for (let i = 0; i < PARTICLE_COUNT; i++) {
          const i3=i*3;
          s[i3+1] += Math.sin(s[i3]*0.5+time*1.5)*0.003 + Math.cos(s[i3+2]*0.3+time*1.2)*0.002;
        }
      }

      const vector = new THREE.Vector3(mouseX, mouseY, 0.5);
      vector.unproject(camera);
      const dir = vector.sub(camera.position).normalize();
      const distance = -camera.position.z / dir.z;
      const mouse3D = camera.position.clone().add(dir.multiplyScalar(distance));
      const localMouse = mouse3D.clone();
      particleSystem.worldToLocal(localMouse);
      if (pointerDown) lastPointerPos.copy(localMouse);

      if (pointerDown) {
        let holdTime = Date.now() - interactionStart;
        if (holdTime < 2500) {
          interactionState='fear'; transitionProgress=0;
          if(navigator.vibrate&&Date.now()-lastVibrateTime>150){navigator.vibrate([10,20]);lastVibrateTime=Date.now();}
        } else {
          interactionState='gather'; transitionProgress=Math.min(1,(holdTime-2500)/2000);
          if(navigator.vibrate&&Date.now()-lastVibrateTime>300-(transitionProgress*150)){navigator.vibrate([50+(transitionProgress*50)]);lastVibrateTime=Date.now();}
        }
      } else if(interactionState!=='bigbang'){interactionState='idle';transitionProgress=Math.max(0,transitionProgress-0.05);}

      const mat = particleSystem.material;
      mat.uniforms.uColor.value.lerp(targetColor, 0.03);
      const targetOpacity = (currentElement==='liquid')?0.25:0.8;
      mat.uniforms.uOpacity.value+=(targetOpacity-mat.uniforms.uOpacity.value)*0.05;
      mat.uniforms.uTime.value = time;

      // Trail strength ramps up during motion transitions
      const isTransitioning = interactionState !== 'idle' || uploadAbsorb > 0.01;
      const trailTarget = isTransitioning ? 1.0 : 0.3;
      mat.uniforms.uTrailStrength.value += (trailTarget - mat.uniforms.uTrailStrength.value) * 0.05;

      const breath = 1.0 + Math.sin(time*2)*0.025 - uploadAbsorb*0.12;
      particleSystem.scale.set(breath, breath, breath);

      const positions = particleSystem.geometry.attributes.position.array;
      const prevPosAttr = particleSystem.geometry.attributes.aPrevPos.array;
      let needsUpdate = false;

      for (let i = 0; i < PARTICLE_COUNT; i++) {
        const i3 = i*3;

        // Store previous position for velocity calculation
        prevPosAttr[i3]   = positions[i3];
        prevPosAttr[i3+1] = positions[i3+1];
        prevPosAttr[i3+2] = positions[i3+2];

        let tx=targetPositions[i3], ty=targetPositions[i3+1], tz=targetPositions[i3+2];
        let dx_r=Math.sin(time*3+i)*0.1, dy_r=Math.cos(time*2.5+i)*0.1, dz_r=Math.sin(time*2+i)*0.1;

        if(currentElement==='water'){dy_r+=Math.sin(targetPositions[i3]*2+time*4)*0.4;dz_r+=Math.cos(targetPositions[i3+1]*2+time*4)*0.4;dx_r*=0.3;dz_r*=0.3;}
        else if(currentElement==='liquid'){const d=Math.sqrt(tx*tx+ty*ty+tz*tz)||1;const w=Math.sin(d*2-time*3)*0.25;dx_r+=(tx/d)*w;dy_r+=(ty/d)*w;dz_r+=(tz/d)*w;}
        else if(currentElement==='fire'){dy_r+=Math.random()*1.5;dx_r+=(Math.random()-0.5)*0.6;dz_r+=(Math.random()-0.5)*0.6;}
        else if(currentElement==='rock'){dx_r*=0.02;dy_r*=0.02;dz_r*=0.02;}
        else if(currentElement==='smoke'){dx_r+=Math.sin(time*0.5+i)*2;dy_r+=Math.cos(time*0.3+i)*2+1;dz_r+=Math.sin(time*0.4+i)*2;}

        tx+=dx_r; ty+=dy_r; tz+=dz_r;

        if(uploadAbsorb>0.001){
          const rad=Math.sqrt(tx*tx+ty*ty+tz*tz)||0.001;
          const sw=time*(10+uploadAbsorb*14)+rad*1.4+(i%113)*0.071;
          const inw=uploadAbsorb*3.4;
          tx+=(-tx/rad)*inw+Math.cos(sw)*rad*0.07*uploadAbsorb;
          ty+=(-ty/rad)*inw+Math.sin(sw)*rad*0.07*uploadAbsorb;
          tz+=(-tz/rad)*inw*0.7;
        }

        const dx=positions[i3]-localMouse.x, dy=positions[i3+1]-localMouse.y, dz=positions[i3+2]-localMouse.z;
        const distSq=dx*dx+dy*dy+dz*dz, dist=Math.sqrt(distSq)||0.001;

        if(interactionState==='fear'){
          if(distSq<20){const f=(20-distSq)/20;tx+=(dx/dist)*f*4+(Math.random()-0.5)*2.5;ty+=(dy/dist)*f*4+(Math.random()-0.5)*2.5;tz+=(dz/dist)*f*4+(Math.random()-0.5)*2.5;}
        } else if(interactionState==='gather'||(transitionProgress>0&&interactionState!=='bigbang')){
          const pull=transitionProgress;
          tx=tx*(1-pull)+localMouse.x*pull;ty=ty*(1-pull)+localMouse.y*pull;tz=tz*(1-pull)+localMouse.z*pull;
          tx+=(Math.random()-0.5)*pull*0.4;ty+=(Math.random()-0.5)*pull*0.4;tz+=(Math.random()-0.5)*pull*0.4;
        } else if(interactionState==='bigbang'){
          const bx=positions[i3]-lastPointerPos.x,by=positions[i3+1]-lastPointerPos.y,bz=positions[i3+2]-lastPointerPos.z;
          const bd=Math.sqrt(bx*bx+by*by+bz*bz)||0.01;
          tx+=(bx/bd)*explosionForce+(Math.random()-0.5)*explosionForce*0.6;
          ty+=(by/bd)*explosionForce+(Math.random()-0.5)*explosionForce*0.6;
          tz+=(bz/bd)*explosionForce+(Math.random()-0.5)*explosionForce*0.6;
        } else {
          if(distSq<6){const f=(6-distSq)/6;tx+=dx*f*1.5;ty+=dy*f*1.5;tz+=dz*f*1.5;}
        }

        const cx=positions[i3],cy=positions[i3+1],cz=positions[i3+2];
        if(Math.abs(tx-cx)>0.001||Math.abs(ty-cy)>0.001||Math.abs(tz-cz)>0.001){
          positions[i3]+=(tx-cx)*MORPH_SPEED;
          positions[i3+1]+=(ty-cy)*MORPH_SPEED;
          positions[i3+2]+=(tz-cz)*MORPH_SPEED;
          needsUpdate=true;
        }
      }

      if(needsUpdate){
        particleSystem.geometry.attributes.position.needsUpdate=true;
        particleSystem.geometry.attributes.aPrevPos.needsUpdate=true;
      }

      if(interactionState==='bigbang'){explosionForce*=0.92;if(explosionForce<0.5){interactionState='idle';transitionProgress=0;}}

      particleSystem.rotation.y+=ROTATION_SPEED;
      particleSystem.rotation.x+=ROTATION_SPEED*0.5;
      touchReactivity+=(1-touchReactivity)*0.05;
      targetRotationX=mouseY*touchReactivity;
      targetRotationY=mouseX*touchReactivity;
      particleSystem.rotation.x+=(targetRotationX-particleSystem.rotation.x)*0.05;
      particleSystem.rotation.y+=(targetRotationY-particleSystem.rotation.y)*0.05;

      renderer.render(scene, camera);
    }
  </script>



  <script>
  // ════════════════════════════════════════════════════════
  //  TASK ENGINE
  // ════════════════════════════════════════════════════════
  const TASK_KEY = 'aether_tasks_v1';
  let tasks = [];

  function loadTasks() {
    try { tasks = JSON.parse(localStorage.getItem(TASK_KEY) || '[]'); } catch(e) { tasks = []; }
  }
  function saveTasks() {
    try { localStorage.setItem(TASK_KEY, JSON.stringify(tasks.slice(0,200))); } catch(e) {}
  }
  function addTask(textOverride, priorityOverride) {
    const input = document.getElementById('taskInput');
    const pSel  = document.getElementById('taskPriority');
    const text  = textOverride || (input ? input.value.trim() : '');
    const prio  = priorityOverride || (pSel ? pSel.value : 'medium');
    if (!text) return;
    tasks.unshift({ id: Date.now().toString(36), text, priority: prio, done: false, ts: Date.now() });
    saveTasks(); renderTasks();
    if (input) input.value = '';
  }
  function toggleTask(id) {
    const t = tasks.find(t => t.id === id);
    if (t) { t.done = !t.done; saveTasks(); renderTasks(); }
  }
  function deleteTask(id) {
    tasks = tasks.filter(t => t.id !== id);
    saveTasks(); renderTasks();
  }
  function renderTasks() {
    const list = document.getElementById('taskList');
    if (!list) return;
    const active = tasks.filter(t => !t.done);
    const done   = tasks.filter(t => t.done);
    const pOrder = { critical:0, high:1, medium:2, low:3 };
    active.sort((a,b) => pOrder[a.priority] - pOrder[b.priority]);
    let html = '';
    if (!tasks.length) {
      html = '<div class="task-empty">the void holds no tasks yet</div>';
    } else {
      if (active.length) {
        html += `<div class="task-section-label">${active.length} active</div>`;
        active.forEach(t => { html += renderTaskCard(t); });
      }
      if (done.length) {
        html += `<div class="task-section-label" style="margin-top:10px">${done.length} done</div>`;
        done.slice(0,5).forEach(t => { html += renderTaskCard(t); });
      }
    }
    list.innerHTML = html;
  }
  function renderTaskCard(t) {
    const ago = timeAgo(t.ts);
    return `<div class="task-card p-${t.priority} ${t.done?'done':''}" id="tc-${t.id}">
      <div class="task-check" onclick="toggleTask('${t.id}')">
        <svg class="task-check-icon" width="9" height="9" viewBox="0 0 9 9" fill="none">
          <path d="M1.5 4.5L3.5 6.5L7.5 2.5" stroke="rgba(255,255,255,0.6)" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </div>
      <div class="task-body">
        <div class="task-text">${escapeHtml(t.text)}</div>
        <div class="task-meta">
          <span class="task-badge p-${t.priority}">${t.priority}</span>
          <span class="task-time">${ago}</span>
        </div>
      </div>
      <button class="task-del" onclick="deleteTask('${t.id}')" title="remove">&#x2715;</button>
    </div>`;
  }
  function timeAgo(ts) {
    const diff = Date.now() - ts;
    if (diff < 60000) return 'just now';
    if (diff < 3600000) return Math.floor(diff/60000) + 'm ago';
    if (diff < 86400000) return Math.floor(diff/3600000) + 'h ago';
    return Math.floor(diff/86400000) + 'd ago';
  }

  // ── detect tasks in AI conversation ─────────────────────────────
  function detectAndSuggestTask(text) {
    const taskPatterns = [
      /\b(you should|you need to|remember to|don't forget to|make sure to|follow up on|schedule|book|call|send|review|update|check|fix|create|prepare|submit|complete)\b/i
    ];
    if (taskPatterns.some(p => p.test(text)) && text.length > 20 && text.length < 250) {
      const strip = text.replace(/<[^>]+>/g,'').trim().slice(0,160);
      if (!strip) return;
      // Glass toast instead of confirm()
      let toast = document.getElementById('aetherTaskSuggest');
      if (!toast) {
        toast = document.createElement('div');
        toast.id = 'aetherTaskSuggest';
        toast.style.cssText = 'position:fixed;bottom:100px;left:50%;transform:translateX(-50%);z-index:9999;background:rgba(255,255,255,0.07);backdrop-filter:blur(30px) saturate(1.4);border:1px solid rgba(255,255,255,0.1);border-radius:16px;padding:14px 20px;display:flex;align-items:center;gap:12px;box-shadow:0 8px 32px rgba(0,0,0,0.3);max-width:440px;';
        document.body.appendChild(toast);
      }
      toast.innerHTML = '<span style="color:rgba(255,255,255,0.6);font-size:12px;flex:1;line-height:1.4;">' + escapeHtml(strip).slice(0,120) + '</span>'
        + '<button id="taskSuggestYes" style="padding:6px 14px;background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.15);border-radius:10px;color:#fff;font-size:11px;cursor:pointer;white-space:nowrap;">add task</button>'
        + '<button id="taskSuggestNo" style="padding:6px 10px;background:none;border:none;color:rgba(255,255,255,0.3);font-size:11px;cursor:pointer;">dismiss</button>';
      toast.style.display = 'flex';
      document.getElementById('taskSuggestYes').onclick = function() {
        addTask(strip, 'high');
        toast.style.display = 'none';
        const taskTab = document.querySelector('[data-tab="tasks"]');
        if (taskTab) { taskTab.click(); setTimeout(()=>{ const allTab = document.querySelector('[data-tab="all"]'); if(allTab) allTab.click(); }, 2500); }
      };
      document.getElementById('taskSuggestNo').onclick = function() { toast.style.display = 'none'; };
      setTimeout(() => { toast.style.display = 'none'; }, 12000);
    }
  }

  // patch into taskTab switching
  document.addEventListener('DOMContentLoaded', () => {
    loadTasks();
    document.querySelectorAll('.aether-tab').forEach(btn => {
      btn.addEventListener('click', () => {
        const tab = btn.dataset.tab;
        const vaultList = document.getElementById('aetherVaultList');
        const vaultSearch = document.getElementById('aetherVaultSearch');
        const intGrid = document.getElementById('aetherIntegrationsGrid');
        const taskPanel = document.getElementById('aetherTaskPanel');
        [vaultList, vaultSearch, intGrid, taskPanel].forEach(el => { if(el) { el.style.display='none'; el.classList.remove('active'); }});
        if (tab === 'integrations') {
          if (intGrid) intGrid.style.display = '';
        } else if (tab === 'tasks') {
          if (taskPanel) { taskPanel.style.display='flex'; taskPanel.classList.add('active'); }
          renderTasks();
        } else {
          if (vaultList) vaultList.style.display = '';
          if (vaultSearch) vaultSearch.style.display = '';
        }
      });
    });
    // enter key on task input
    const ti = document.getElementById('taskInput');
    if (ti) ti.addEventListener('keydown', e => { if (e.key === 'Enter') addTask(); });
  });

  // ════════════════════════════════════════════════════════
  //  WORKFLOW LEARNING ENGINE
  // ════════════════════════════════════════════════════════
  const WF_KEY = 'aether_workflow_v1';
  let wfData = { patterns:{}, sessionCount:0, lastSeen:{}, hourMap:{}, topicMap:{} };

  function loadWF() {
    try { const s = localStorage.getItem(WF_KEY); if(s) wfData = {...wfData, ...JSON.parse(s)}; } catch(e){}
    wfData.sessionCount = (wfData.sessionCount||0) + 1;
    saveWF();
  }
  function saveWF() {
    try { localStorage.setItem(WF_KEY, JSON.stringify(wfData)); } catch(e) {}
  }
  function trackInput(text) {
    const lower = text.toLowerCase();
    const hour = new Date().getHours();
    wfData.hourMap[hour] = (wfData.hourMap[hour]||0) + 1;
    const topics = [
      { key:'email',    re:/\bemail|inbox|reply|send|gmail|outlook\b/i },
      { key:'tasks',    re:/\btask|todo|reminder|deadline|schedule\b/i },
      { key:'drive',    re:/\bdrive|file|doc|upload|sheet|pdf\b/i },
      { key:'code',     re:/\bcode|bug|git|repo|deploy|function|api\b/i },
      { key:'calendar', re:/\bmeet|calendar|call|appointment|event\b/i },
      { key:'data',     re:/\bdata|database|query|sql|table|supabase\b/i },
      { key:'research', re:/\bsearch|find|look up|summarize|analyze|report\b/i },
    ];
    topics.forEach(t => { if(t.re.test(lower)) { wfData.topicMap[t.key] = (wfData.topicMap[t.key]||0)+1; }});
    saveWF();
    updateChips();
    updateWorkflowInsight();
  }
  function getTopTopics(n=4) {
    return Object.entries(wfData.topicMap||{}).sort((a,b)=>b[1]-a[1]).slice(0,n).map(e=>e[0]);
  }
  function getPeakHour() {
    const map = wfData.hourMap||{};
    if (!Object.keys(map).length) return null;
    return parseInt(Object.entries(map).sort((a,b)=>b[1]-a[1])[0][0]);
  }

  const CHIP_SUGGESTIONS = {
    email:    ['check my inbox', 'summarize unread emails', 'draft a reply'],
    tasks:    ['show my tasks', 'add a task', 'what is urgent?'],
    drive:    ['find a file', 'summarize a doc', 'upload to drive'],
    code:     ['review my code', 'check github', 'debug this'],
    calendar: ['what is on my calendar', 'schedule a meeting', 'free slots today'],
    data:     ['query my database', 'show table data', 'run a report'],
    research: ['search the web', 'summarize this', 'find recent news'],
  };
  const DEFAULT_CHIPS = ['check my inbox', 'show my tasks', 'search the web', 'query database'];

  function updateChips() {
    const bar = document.getElementById('aetherChipBar');
    if (!bar) return;
    const top = getTopTopics(3);
    let chips = [];
    top.forEach(t => { if(CHIP_SUGGESTIONS[t]) chips.push(CHIP_SUGGESTIONS[t][0]); });
    if (chips.length < 3) {
      DEFAULT_CHIPS.forEach(c => { if (!chips.includes(c) && chips.length < 4) chips.push(c); });
    }
    bar.innerHTML = chips.map((c,i) =>
      `<div class="aether-chip${i===0?' pulse-chip':''}" onclick="injectChip(this.textContent)">${c}</div>`
    ).join('');
    bar.classList.add('visible');
  }
  function injectChip(text) {
    const inp = document.getElementById('aetherInput');
    if (!inp) return;
    inp.value = text; inp.focus();
    inp.style.height='auto'; inp.style.height = Math.min(inp.scrollHeight, 220)+'px';
  }
  function updateWorkflowInsight() {
    const strip = document.getElementById('aetherWorkflowStrip');
    const txt = document.getElementById('workflowInsightText');
    if (!strip || !txt) return;
    const top = getTopTopics(1)[0];
    const peak = getPeakHour();
    const sessions = wfData.sessionCount||1;
    let msg = 'learning your patterns…';
    if (sessions >= 1 && top) {
      const peakStr = peak !== null ? ` · peak at ${peak}:00` : '';
      msg = `focus: ${top}${peakStr} · session ${sessions}`;
    }
    txt.textContent = msg;
    strip.classList.add('visible');
    // Strip stays visible — learning is always on
  }

  // init workflow
  document.addEventListener('DOMContentLoaded', () => {
    loadWF(); updateChips();
    // patch send to track input
    const sendBtn = document.getElementById('aetherSend');
    const inp = document.getElementById('aetherInput');
    function patchTrack() {
      const val = inp ? inp.value.trim() : '';
      if (val) trackInput(val);
    }
    if (sendBtn) sendBtn.addEventListener('click', patchTrack, true);
    if (inp) inp.addEventListener('keydown', e => {
      if (e.key === 'Enter' && !e.shiftKey) patchTrack();
    }, true);
  });
  </script>

</body>
</html>
